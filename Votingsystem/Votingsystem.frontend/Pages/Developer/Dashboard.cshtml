@page
@model Votingsystem.frontend.Pages.Developer.DashboardModel
@{
    ViewData["Title"] = "Developer Dashboard";
}

<section class="space-y-8">

    <!-- ═══════════════════════════════════════════════
         HEADER
         ═══════════════════════════════════════════════ -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div class="flex items-center gap-3">
            <div style="width:42px;height:42px;border-radius:14px;background:rgba(124,58,237,0.15);border:1px solid rgba(124,58,237,0.35);display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;">
                ⚡
            </div>
            <div>
                <h1 class="text-2xl font-bold" style="color:var(--pb-text);line-height:1.2;">Developer Dashboard</h1>
                <p style="color:var(--pb-muted);font-size:0.85rem;" class="mt-0.5">
                    System overview &middot; admin requests &middot; user management
                </p>
            </div>
        </div>
        @if (Model.PendingRequests > 0)
        {
            <div style="display:flex;align-items:center;gap:8px;background:rgba(212,175,55,0.12);border:1px solid rgba(212,175,55,0.3);border-radius:10px;padding:8px 14px;">
                <span style="font-size:1rem;">📬</span>
                <span style="color:var(--pb-gold);font-size:0.85rem;font-weight:600;">@Model.PendingRequests pending admin request@(Model.PendingRequests > 1 ? "s" : "")</span>
            </div>
        }
    </div>

    <!-- ═══════════════════════════════════════════════
         KPI CARDS
         ═══════════════════════════════════════════════ -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">

        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:rgba(59,130,246,0.12);border-color:rgba(59,130,246,0.3);">👥</div>
                <span class="pb-badge" style="font-size:0.68rem;background:rgba(59,130,246,0.12);color:#60a5fa;border-color:rgba(59,130,246,0.3);">All time</span>
            </div>
            <div>
                <p class="pb-stat-value">@Model.TotalUsers</p>
                <p class="pb-stat-label" style="margin-top:4px;">Total Users</p>
            </div>
        </div>

        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:var(--pb-goldSubtle);border-color:var(--pb-goldBorder);">🛡️</div>
                <span class="pb-badge pb-badge-gold" style="font-size:0.68rem;">Admins</span>
            </div>
            <div>
                <p class="pb-stat-value">@Model.TotalAdmins</p>
                <p class="pb-stat-label" style="margin-top:4px;">Admin Accounts</p>
            </div>
        </div>

        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:rgba(124,58,237,0.15);border-color:rgba(124,58,237,0.35);">📬</div>
                @if (Model.PendingRequests > 0)
                {
                    <span class="pb-badge pb-badge-gold" style="font-size:0.68rem;">Action needed</span>
                }
                else
                {
                    <span class="pb-badge pb-badge-success" style="font-size:0.68rem;">Clear</span>
                }
            </div>
            <div>
                <p class="pb-stat-value">@Model.PendingRequests</p>
                <p class="pb-stat-label" style="margin-top:4px;">Admin Requests</p>
            </div>
        </div>

        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:rgba(52,211,153,0.12);border-color:rgba(52,211,153,0.3);">🗳️</div>
                <span class="pb-badge pb-badge-success" style="font-size:0.68rem;">System-wide</span>
            </div>
            <div>
                <p class="pb-stat-value">@Model.TotalElections</p>
                <p class="pb-stat-label" style="margin-top:4px;">Total Elections</p>
            </div>
        </div>

        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:rgba(52,211,153,0.12);border-color:rgba(52,211,153,0.3);">▶️</div>
                <span class="pb-badge pb-badge-success" style="font-size:0.68rem;">Live</span>
            </div>
            <div>
                <p class="pb-stat-value">@Model.ActiveElections</p>
                <p class="pb-stat-label" style="margin-top:4px;">Active Elections</p>
            </div>
        </div>

        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:rgba(59,130,246,0.12);border-color:rgba(59,130,246,0.3);">📊</div>
                <span class="pb-badge" style="font-size:0.68rem;background:rgba(59,130,246,0.12);color:#60a5fa;border-color:rgba(59,130,246,0.3);">All time</span>
            </div>
            <div>
                <p class="pb-stat-value">@Model.TotalVotes</p>
                <p class="pb-stat-label" style="margin-top:4px;">Total Votes Cast</p>
            </div>
        </div>

    </div>

    <!-- ═══════════════════════════════════════════════
         ADMIN REQUEST INBOX
         ═══════════════════════════════════════════════ -->
    <div class="pb-card" style="padding:24px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
            <div class="dash-icon-wrap" style="background:var(--pb-goldSubtle);border-color:var(--pb-goldBorder);width:34px;height:34px;font-size:1rem;">📬</div>
            <div>
                <h2 style="color:var(--pb-text);font-size:1.05rem;font-weight:700;line-height:1.2;">Admin Request Inbox</h2>
                <p style="color:var(--pb-muted);font-size:0.78rem;">Users who requested admin access</p>
            </div>
        </div>

        @if (!Model.AdminRequests.Any())
        {
            <div style="text-align:center;padding:32px 0;color:var(--pb-muted);">
                <div style="font-size:2rem;margin-bottom:8px;">✅</div>
                <p style="font-size:0.9rem;">No pending admin requests</p>
            </div>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:12px;">
                @foreach (var user in Model.AdminRequests)
                {
                    <div style="background:var(--pb-cardFlat);border:1px solid var(--pb-border);border-radius:12px;padding:16px 18px;">
                        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div class="pb-avatar" style="width:38px;height:38px;font-size:1.2rem;flex-shrink:0;">@user.Avatar</div>
                                <div>
                                    <p style="color:var(--pb-text);font-weight:600;font-size:0.9rem;">@user.FullName</p>
                                    <p style="color:var(--pb-muted);font-size:0.78rem;">@user.Email</p>
                                    @if (!string.IsNullOrWhiteSpace(user.AdminRequestReason))
                                    {
                                        <p style="color:var(--pb-muted);font-size:0.78rem;margin-top:6px;max-width:480px;line-height:1.5;">
                                            <span style="color:var(--pb-gold);font-weight:600;">Reason: </span>@user.AdminRequestReason
                                        </p>
                                    }
                                </div>
                            </div>
                            <div style="display:flex;gap:8px;flex-shrink:0;align-items:center;">
                                <form method="post" asp-page-handler="Approve">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="pb-btn pb-btn-gold" style="padding:6px 14px;font-size:0.8rem;">
                                        ✓ Approve
                                    </button>
                                </form>
                                <form method="post" asp-page-handler="Deny">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="pb-btn pb-btn-danger-outline" style="padding:6px 14px;font-size:0.8rem;">
                                        ✕ Deny
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ═══════════════════════════════════════════════
         USER MANAGEMENT
         ═══════════════════════════════════════════════ -->
    <div class="pb-card" style="padding:24px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
            <div class="dash-icon-wrap" style="background:rgba(59,130,246,0.12);border-color:rgba(59,130,246,0.3);width:34px;height:34px;font-size:1rem;">👥</div>
            <div>
                <h2 style="color:var(--pb-text);font-size:1.05rem;font-weight:700;line-height:1.2;">All Users</h2>
                <p style="color:var(--pb-muted);font-size:0.78rem;">Manage roles and account status</p>
            </div>
        </div>

        <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:0.85rem;">
                <thead>
                    <tr style="border-bottom:1px solid var(--pb-border);">
                        <th style="text-align:left;padding:8px 12px;color:var(--pb-muted);font-weight:600;">User</th>
                        <th style="text-align:left;padding:8px 12px;color:var(--pb-muted);font-weight:600;">Email</th>
                        <th style="text-align:left;padding:8px 12px;color:var(--pb-muted);font-weight:600;">Role</th>
                        <th style="text-align:left;padding:8px 12px;color:var(--pb-muted);font-weight:600;">Status</th>
                        <th style="text-align:left;padding:8px 12px;color:var(--pb-muted);font-weight:600;">Joined</th>
                        <th style="text-align:right;padding:8px 12px;color:var(--pb-muted);font-weight:600;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.AllUsers)
                    {
                        <tr style="border-bottom:1px solid var(--pb-border);">
                            <td style="padding:10px 12px;">
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="pb-avatar" style="width:32px;height:32px;font-size:1rem;flex-shrink:0;">@user.Avatar</div>
                                    <span style="color:var(--pb-text);font-weight:500;">@user.FullName</span>
                                </div>
                            </td>
                            <td style="padding:10px 12px;color:var(--pb-muted);">@user.Email</td>
                            <td style="padding:10px 12px;">
                                @if (user.Role == "Developer")
                                {
                                    <span class="pb-badge" style="background:rgba(124,58,237,0.15);color:#a78bfa;border-color:rgba(124,58,237,0.35);">⚡ Developer</span>
                                }
                                else if (user.Role == "Admin")
                                {
                                    <span class="pb-badge pb-badge-gold">🛡️ Admin</span>
                                }
                                else
                                {
                                    <span class="pb-badge" style="background:rgba(59,130,246,0.1);color:#60a5fa;border-color:rgba(59,130,246,0.25);">👤 User</span>
                                }
                            </td>
                            <td style="padding:10px 12px;">
                                @if (user.IsActive)
                                {
                                    <span class="pb-badge pb-badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="pb-badge pb-badge-danger">Inactive</span>
                                }
                            </td>
                            <td style="padding:10px 12px;color:var(--pb-muted);">@user.CreatedAt.ToString("MMM d, yyyy")</td>
                            <td style="padding:10px 12px;text-align:right;">
                                @if (user.Id.ToString() != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                {
                                    <div style="display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap;">
                                        @if (user.Role != "Admin")
                                        {
                                            <form method="post" asp-page-handler="SetRole">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <input type="hidden" name="role" value="Admin" />
                                                <button type="submit" class="pb-btn pb-btn-outline" style="padding:4px 10px;font-size:0.75rem;">→ Admin</button>
                                            </form>
                                        }
                                        @if (user.Role != "User")
                                        {
                                            <form method="post" asp-page-handler="SetRole">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <input type="hidden" name="role" value="User" />
                                                <button type="submit" class="pb-btn pb-btn-outline" style="padding:4px 10px;font-size:0.75rem;">→ User</button>
                                            </form>
                                        }
                                        <form method="post" asp-page-handler="ToggleActive">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="pb-btn @(user.IsActive ? "pb-btn-danger-outline" : "pb-btn-outline")" style="padding:4px 10px;font-size:0.75rem;">
                                                @(user.IsActive ? "Disable" : "Enable")
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span style="color:var(--pb-muted);font-size:0.75rem;">You</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</section>
