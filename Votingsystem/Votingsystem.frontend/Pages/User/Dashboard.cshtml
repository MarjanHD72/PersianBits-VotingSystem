@page
@model Votingsystem.frontend.Pages.User.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    var avatar = User.FindFirst("Avatar")?.Value ?? "😀";
    var name   = User.Identity?.Name ?? "Voter";
}

<section class="space-y-8">

    <!-- ── Welcome banner ────────────────────────────────────────────────── -->
    <div class="pb-card p-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div style="display:flex;align-items:center;gap:16px;">
                <div style="width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;
                            font-size:1.8rem;background:var(--pb-avatarBg);border:2px solid var(--pb-gold);
                            box-shadow:var(--pb-shadowGlow);flex-shrink:0;">@avatar</div>
                <div>
                    <p style="font-size:0.75rem;color:var(--pb-muted2);letter-spacing:0.06em;text-transform:uppercase;font-weight:600;">Welcome back</p>
                    <h1 class="text-xl font-bold" style="color:var(--pb-text);margin-top:2px;">@name</h1>
                    <p style="font-size:0.8rem;color:var(--pb-muted);margin-top:2px;">
                        Voter &middot;
                        <span style="color:var(--pb-gold);font-weight:600;">@Model.VotesCount vote@(Model.VotesCount == 1 ? "" : "s") cast</span>
                    </p>
                </div>
            </div>
            <a asp-page="/User/Profile" class="pb-btn pb-btn-outline text-sm" style="flex-shrink:0;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20v-1a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v1"/></svg>
                My Profile
            </a>
        </div>
    </div>

    <!-- ── Notifications ────────────────────────────────────────────────────── -->
    @if (Model.UnreadNotifications.Count > 0)
    {
        <div class="space-y-2">
            @foreach (var notif in Model.UnreadNotifications)
            {
                var typeIcon = notif.Election.Type switch {
                    "election"    => "🗳️",
                    "rating"      => "⭐",
                    "text"        => "📝",
                    "multichoice" => "☑️",
                    "ranking"     => "🏆",
                    _             => "📊"
                };
                <div style="background:var(--pb-warningBg);border:1px solid var(--pb-warningBdr);border-radius:16px;padding:14px 18px;
                            display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
                    <div style="display:flex;align-items:center;gap:10px;min-width:0;flex:1;">
                        <span style="font-size:1.3rem;flex-shrink:0;">@typeIcon</span>
                        <div style="min-width:0;">
                            <p style="font-weight:700;color:var(--pb-warning);font-size:0.9rem;">Results are in!</p>
                            <p style="font-size:0.8rem;color:var(--pb-muted);margin-top:1px;word-break:break-word;">
                                <strong style="color:var(--pb-text);">@notif.Election.Title</strong> has closed. See how it turned out.
                            </p>
                        </div>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
                        <a href="/Poll/Results?session=@notif.Election.SessionId" class="pb-btn pb-btn-gold text-sm" style="padding:0.45rem 1rem;font-size:0.8rem;">
                            View Results
                        </a>
                        <form method="post" asp-page-handler="Dismiss" style="margin:0;">
                            <input type="hidden" name="id" value="@notif.Id" />
                            <button type="submit" title="Dismiss"
                                    style="background:transparent;border:1px solid var(--pb-warningBdr);color:var(--pb-warning);
                                           border-radius:8px;padding:5px 9px;cursor:pointer;font-size:0.85rem;line-height:1;">
                                ✕
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }

    <!-- ── Join by Session ID ─────────────────────────────────────────────── -->
    <div class="pb-card p-6 space-y-4">
        <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:40px;height:40px;border-radius:12px;background:var(--pb-goldSubtle);border:1px solid var(--pb-goldBorder);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;">🔗</div>
            <div>
                <h2 class="font-semibold" style="color:var(--pb-text);">Join an election</h2>
                <p style="font-size:0.78rem;color:var(--pb-muted2);">Enter a Session ID shared by the admin</p>
            </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
            <input id="joinInput" class="flex-1 px-4 py-3 rounded-xl"
                   placeholder="Enter Session ID  e.g. 7F2A-19KD" />
            <button id="joinBtn" class="pb-btn pb-btn-gold">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                Join
            </button>
        </div>
        <p id="joinError" style="display:none;color:var(--pb-danger);font-size:0.875rem;"></p>
    </div>

    <!-- ── Your votes (participated) ────────────────────────────────────────── -->
    @if (Model.VotedElections.Count > 0)
    {
        <div class="pb-card p-5 space-y-4">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div>
                    <h2 class="font-bold text-lg" style="color:var(--pb-text);">Your Votes</h2>
                    <p style="font-size:0.78rem;color:var(--pb-muted2);margin-top:2px;">Elections you participated in — click to review your answer</p>
                </div>
                <span class="pb-badge pb-badge-gold" style="font-size:0.72rem;">@Model.VotedElections.Count voted</span>
            </div>

            @foreach (var el in Model.VotedElections)
            {
                var typeIcon = el.Type switch {
                    "election"    => "🗳️",
                    "rating"      => "⭐",
                    "text"        => "📝",
                    "multichoice" => "☑️",
                    "ranking"     => "🏆",
                    _             => "📊"
                };
                var typeLabel = el.Type switch {
                    "election"    => "Election",
                    "rating"      => "Rating",
                    "text"        => "Text",
                    "multichoice" => "Multi-choice",
                    "ranking"     => "Ranking",
                    _             => el.Type
                };
                var statusBadge = el.Status switch {
                    "running" => ("pb-badge-success", "Live"),
                    "closed"  => ("pb-badge-danger",  "Closed"),
                    _         => ("pb-badge-draft",   "Draft")
                };

                <div class="pb-card-flat" style="padding:16px 18px;display:flex;flex-direction:column;gap:10px;">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                        <div style="display:flex;align-items:center;gap:12px;min-width:0;flex:1;">
                            <div style="width:42px;height:42px;border-radius:13px;background:var(--pb-goldSubtle);border:1px solid var(--pb-goldBorder);
                                        display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;">@typeIcon</div>
                            <div style="min-width:0;">
                                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                                    <p style="font-weight:700;color:var(--pb-text);font-size:0.95rem;word-break:break-word;">@el.Title</p>
                                    <span class="pb-badge @statusBadge.Item1" style="font-size:0.68rem;">@statusBadge.Item2</span>
                                    <span class="pb-badge pb-badge-gold" style="font-size:0.68rem;">@typeLabel</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:6px;margin-top:4px;">
                                    <span style="font-size:0.72rem;color:var(--pb-success);">✓ Voted</span>
                                </div>
                            </div>
                        </div>
                        @if (el.Status == "closed")
                        {
                            <a href="/Poll/Results?session=@el.SessionId" class="pb-btn pb-btn-gold text-sm" style="flex-shrink:0;padding:0.55rem 1.1rem;">
                                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
                                Results
                            </a>
                        }
                        else
                        {
                            <a href="/Poll/Take?session=@el.SessionId" class="pb-btn pb-btn-outline text-sm" style="flex-shrink:0;padding:0.55rem 1.1rem;">
                                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                                Review
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <!-- ── Available elections ────────────────────────────────────────────── -->
    <div class="pb-card p-5 space-y-4">
        <div style="display:flex;align-items:center;justify-content:space-between;">
            <div>
                <h2 class="font-bold text-lg" style="color:var(--pb-text);">Available Now</h2>
                <p style="font-size:0.78rem;color:var(--pb-muted2);margin-top:2px;">Running elections you haven't voted in yet</p>
            </div>
            @if (Model.AvailableElections.Count > 0)
            {
                <span class="pb-badge pb-badge-success" style="font-size:0.72rem;">
                    <span style="width:6px;height:6px;border-radius:50%;background:var(--pb-success);display:inline-block;margin-right:4px;animation:upulse 1.5s infinite;"></span>
                    @Model.AvailableElections.Count live
                </span>
            }
        </div>

        @if (Model.AvailableElections.Count == 0)
        {
            <div style="text-align:center;padding:36px 20px;">
                <div style="font-size:2.5rem;margin-bottom:12px;">🗳️</div>
                <p style="color:var(--pb-muted);font-size:0.9rem;font-weight:500;">No elections available right now.</p>
                <p style="color:var(--pb-muted2);font-size:0.8rem;margin-top:4px;line-height:1.5;">
                    Ask an admin for a Session ID to join one directly,<br/>or check back later.
                </p>
            </div>
        }

        @foreach (var el in Model.AvailableElections)
        {
            var typeIcon = el.Type switch {
                "election"    => "🗳️",
                "rating"      => "⭐",
                "text"        => "📝",
                "multichoice" => "☑️",
                "ranking"     => "🏆",
                _             => "📊"
            };
            var typeLabel = el.Type switch {
                "election"    => "Election",
                "rating"      => "Rating",
                "text"        => "Text",
                "multichoice" => "Multi-choice",
                "ranking"     => "Ranking",
                _             => el.Type
            };

            <div class="pb-card-flat" style="padding:16px 18px;display:flex;flex-direction:column;gap:10px;">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                    <div style="display:flex;align-items:center;gap:12px;min-width:0;flex:1;">
                        <div style="width:42px;height:42px;border-radius:13px;background:var(--pb-goldSubtle);border:1px solid var(--pb-goldBorder);
                                    display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;">@typeIcon</div>
                        <div style="min-width:0;">
                            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                                <p style="font-weight:700;color:var(--pb-text);font-size:0.95rem;word-break:break-word;">@el.Title</p>
                                <span class="pb-badge pb-badge-success" style="font-size:0.68rem;">
                                    <span style="width:5px;height:5px;border-radius:50%;background:var(--pb-success);display:inline-block;margin-right:3px;animation:upulse 1.5s infinite;"></span>
                                    Live
                                </span>
                                <span class="pb-badge pb-badge-gold" style="font-size:0.68rem;">@typeLabel</span>
                            </div>
                            <div style="display:flex;align-items:center;gap:8px;margin-top:4px;flex-wrap:wrap;">
                                <span style="font-size:0.75rem;color:var(--pb-muted2);">Session:</span>
                                <code style="font-size:0.75rem;font-family:monospace;letter-spacing:0.08em;
                                             background:var(--pb-goldSubtle);border:1px solid var(--pb-goldBorder);
                                             color:var(--pb-gold);padding:2px 8px;border-radius:6px;">@el.SessionId</code>
                            </div>
                        </div>
                    </div>
                    <a href="/Poll/Take?session=@el.SessionId" class="pb-btn pb-btn-gold text-sm" style="flex-shrink:0;padding:0.55rem 1.1rem;">
                        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M5 3l14 9-14 9V3z"/></svg>
                        Vote Now
                    </a>
                </div>
            </div>
        }
    </div>

</section>

<style>
    @@keyframes upulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
</style>

@section Scripts {
    <script>
        (() => {
            const btn   = document.getElementById('joinBtn');
            const input = document.getElementById('joinInput');
            const err   = document.getElementById('joinError');
            btn?.addEventListener('click', () => {
                const s = (input.value || '').trim();
                if (!s) { err.textContent = 'Please enter a Session ID.'; err.style.display = 'block'; return; }
                err.style.display = 'none';
                window.location.href = '/Poll/Take?session=' + encodeURIComponent(s);
            });
            input?.addEventListener('keydown', e => { if (e.key === 'Enter') btn.click(); });
        })();
    </script>
}
