@page
@model Votingsystem.frontend.Pages.IndexModel
@{
    ViewData["Title"] = "PersianBits Voting Centre";
}

<style>
    .hero-step {
        display: flex; flex-direction: column; align-items: center; text-align: center;
        gap: 5px; flex: 1; min-width: 0;
    }
    .hero-step-icon {
        width: 34px; height: 34px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
        background: var(--pb-goldSubtle); border: 1px solid var(--pb-goldBorder);
        flex-shrink: 0;
    }
    .hero-step-connector {
        width: 32px; height: 1px;
        background: linear-gradient(90deg, var(--pb-goldBorder), transparent);
        flex-shrink: 0; align-self: center; margin-top: -14px;
    }
    @@media (max-width: 640px) { .hero-step-connector { display: none; } }
    .auth-card {
        display: flex; align-items: center; gap: 14px;
        padding: 20px 24px; border-radius: 18px; text-decoration: none;
        background: var(--pb-glass); border: 1px solid var(--pb-border);
        backdrop-filter: blur(12px); transition: all 0.2s ease;
        color: var(--pb-text);
    }
    .auth-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--pb-shadowGlow);
        border-color: var(--pb-goldBorder);
    }
    .auth-card-icon {
        width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center; font-size: 1.4rem;
    }
</style>

<section class="flex flex-col items-center justify-center gap-4 pb-4" style="min-height:calc(100vh - 64px);">

    <!-- ── Hero ─────────────────────────────────────────────────────────── -->
    <div class="flex flex-col items-center text-center gap-2 max-w-2xl w-full">
        <div class="pb-hero-logo" style="transform:scale(0.75);margin:-8px 0;">
            <img src="~/assets/logo.jpg" alt="PersianBits logo" />
        </div>
        <div class="space-y-1">
            <h1 class="text-3xl sm:text-4xl font-bold tracking-tight" style="color:var(--pb-text);line-height:1.15;">
                PersianBits
                <span style="background:linear-gradient(135deg,var(--pb-gold),var(--pb-goldGlow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
                    Voting Centre
                </span>
            </h1>
            <p style="color:var(--pb-muted);font-size:0.9rem;">
                Secure &middot; Modern &middot; Transparent Elections
            </p>
        </div>
    </div>

    <!-- ── How it works ──────────────────────────────────────────────────── -->
    <div class="w-full max-w-2xl">
        <p style="text-align:center;font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--pb-muted2);margin-bottom:8px;">
            How it works
        </p>
        <div style="display:flex;align-items:flex-start;flex-wrap:wrap;justify-content:center;gap:6px;">
            <div class="hero-step">
                <div class="hero-step-icon">🔑</div>
                <p style="font-size:0.75rem;font-weight:700;color:var(--pb-text);">Get Session ID</p>
                <p style="font-size:0.68rem;color:var(--pb-muted2);line-height:1.3;">Ask the admin for the session code</p>
            </div>
            <div class="hero-step-connector"></div>
            <div class="hero-step">
                <div class="hero-step-icon">✍️</div>
                <p style="font-size:0.75rem;font-weight:700;color:var(--pb-text);">Sign In & Vote</p>
                <p style="font-size:0.68rem;color:var(--pb-muted2);line-height:1.3;">Login and submit your vote securely</p>
            </div>
            <div class="hero-step-connector" style="background:linear-gradient(90deg,transparent,var(--pb-goldBorder));"></div>
            <div class="hero-step">
                <div class="hero-step-icon">📊</div>
                <p style="font-size:0.75rem;font-weight:700;color:var(--pb-text);">See Results</p>
                <p style="font-size:0.68rem;color:var(--pb-muted2);line-height:1.3;">Results update in real time</p>
            </div>
        </div>
    </div>

    <!-- ── Session join ──────────────────────────────────────────────────── -->
    <div class="w-full max-w-2xl">
        <div class="pb-card p-6 space-y-4">
            <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:44px;height:44px;border-radius:13px;background:var(--pb-goldSubtle);border:1px solid var(--pb-goldBorder);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">🗳️</div>
                <div>
                    <p style="font-weight:700;color:var(--pb-text);font-size:1rem;">Have a Session ID?</p>
                    <p style="font-size:0.78rem;color:var(--pb-muted2);">Join an election or poll directly</p>
                </div>
            </div>
            <div class="flex flex-col sm:flex-row gap-3">
                <input id="sessionInput" class="flex-1 px-4 py-3 rounded-xl"
                       placeholder="Enter Session ID  e.g. 7F2A-19KD" />
                <button id="joinBtn" type="button" class="pb-btn pb-btn-gold">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    Join
                </button>
            </div>
            <p id="joinError" style="display:none;color:var(--pb-danger);font-size:0.82rem;"></p>
            <p style="font-size:0.75rem;color:var(--pb-muted2);">
                If you're not signed in, you'll be prompted to log in first.
            </p>
        </div>
    </div>

    <!-- ── Auth cards ────────────────────────────────────────────────────── -->
    <div class="w-full max-w-2xl grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a asp-page="/Auth/Login" class="auth-card">
            <div class="auth-card-icon" style="background:var(--pb-goldSubtle);border:1px solid var(--pb-goldBorder);">🔓</div>
            <div style="flex:1;min-width:0;">
                <p style="font-weight:700;font-size:0.95rem;">Sign In</p>
                <p style="font-size:0.78rem;color:var(--pb-muted2);margin-top:2px;">Access your account</p>
            </div>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--pb-muted2);flex-shrink:0;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a asp-page="/Auth/Register/Index" class="auth-card">
            <div class="auth-card-icon" style="background:rgba(52,211,153,0.10);border:1px solid rgba(52,211,153,0.25);">✨</div>
            <div style="flex:1;min-width:0;">
                <p style="font-weight:700;font-size:0.95rem;">Create Account</p>
                <p style="font-size:0.78rem;color:var(--pb-muted2);margin-top:2px;">Register to participate</p>
            </div>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--pb-muted2);flex-shrink:0;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
    </div>

</section>

@section Scripts {
    <script>
        (() => {
            const btn   = document.getElementById('joinBtn');
            const input = document.getElementById('sessionInput');
            const err   = document.getElementById('joinError');
            btn.addEventListener('click', () => {
                const s = (input.value || '').trim();
                if (!s) { err.textContent = 'Please enter a Session ID.'; err.style.display = 'block'; return; }
                err.style.display = 'none';
                window.location.href = '/Poll/Take?session=' + encodeURIComponent(s);
            });
            input.addEventListener('keydown', e => { if (e.key === 'Enter') btn.click(); });
        })();
    </script>
}
