@page
@model Votingsystem.frontend.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Users";
}

@*
    USERS (Admin) 
    Purpose:
    - Admin can view users and basic info
        - Load users from Database
        - Support searching/filterin
        - View full user profile and activity
*@

<section class="max-w-6xl mx-auto space-y-6">

    <!-- Header -->
    <div class="flex items-start justify-between gap-4">
        <div class="space-y-1">
            <h1 class="text-2xl font-semibold">Users</h1>
            <p class="text-slate-400">Manage voters and creators. Frontend prototype (mock data).</p>
        </div>

        <a asp-page="/Admin/Dashboard"
           class="px-4 py-3 rounded-xl border border-slate-800 hover:bg-slate-800/60">
            Back
        </a>
    </div>

    <!-- Search -->
    <div>
        <input class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800
                   focus:outline-none focus:ring-2 focus:ring-indigo-500"
               placeholder="Search by name, username, email..." />
    </div>

    <!-- Users list -->
    <div class="rounded-2xl border border-slate-800 bg-slate-900/40 overflow-hidden">
        <div class="px-5 py-4 flex items-center justify-between">
            <h2 class="font-semibold">User List</h2>
            <span class="text-xs text-slate-400">Mock data</span>
        </div>

        <div class="divide-y divide-slate-800">

            <!-- User row -->
            <div class="px-5 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="h-10 w-10 rounded-xl bg-[#D4AF37]/20 border border-[#D4AF37]/30 flex items-center justify-center">
                        <span class="text-indigo-300 font-semibold">M</span>
                    </div>
                    <div>
                        <p class="font-medium">Mamad Saberi <span class="text-slate-400 text-sm">@@mamad</span></p>
                        <p class="text-sm text-slate-400">mamad@example.com</p>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                    <span class="text-xs px-2 py-1 rounded-full bg-emerald-500/15 text-emerald-300 border border-emerald-500/25">
                        Active
                    </span>

                    <a asp-page="/Admin/UserDetails"
                       class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">
                        View
                    </a>
                    <button type="button"
                            class="px-3 py-2 rounded-xl border border-rose-500/30 hover:bg-rose-500/10 text-sm text-rose-300">
                        Disable
                    </button>
                </div>
            </div>

            <!-- User row -->
            <div class="px-5 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="h-10 w-10 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center">
                        <span class="text-slate-200 font-semibold">S</span>
                    </div>
                    <div>
                        <p class="font-medium">Sara Mohammadi <span class="text-slate-400 text-sm">@@sara_m</span></p>
                        <p class="text-sm text-slate-400">sara@example.com</p>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                    <span class="text-xs px-2 py-1 rounded-full bg-emerald-500/15 text-emerald-300 border border-emerald-500/25">
                        Active
                    </span>
                    <span class="text-xs px-2 py-1 rounded-full bg-slate-500/20 text-slate-300 border border-slate-500/30">
                        User
                    </span>

                    <a asp-page="/Admin/UserDetails"
                       class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">
                        View
                    </a>
                    <button type="button"
                            class="px-3 py-2 rounded-xl border border-rose-500/30 hover:bg-rose-500/10 text-sm text-rose-300">
                        Disable
                    </button>
                </div>
            </div>

            <!-- User row -->
            <div class="px-5 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="h-10 w-10 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center">
                        <span class="text-slate-200 font-semibold">A</span>
                    </div>
                    <div>
                        <p class="font-medium">Ali Rezaei <span class="text-slate-400 text-sm">@@ali_r</span></p>
                        <p class="text-sm text-slate-400">ali@example.com</p>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                    <span class="text-xs px-2 py-1 rounded-full bg-emerald-500/15 text-emerald-300 border border-emerald-500/25">
                        Active
                    </span>

                    <a asp-page="/Admin/UserDetails"
                       class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">
                        View
                    </a>
                    <button type="button"
                            class="px-3 py-2 rounded-xl border border-rose-500/30 hover:bg-rose-500/10 text-sm text-rose-300">
                        Disable
                    </button>
                </div>
            </div>

        </div>
    </div>

    <p class="text-xs text-slate-500">
        Backend later: search, pagination, real actions (disable/approve), and audit logs.
    </p>

</section>