@page
@model Votingsystem.frontend.Pages.Admin.Builders.RatingScaleModel
@{ ViewData["Title"] = "Rating Scale Builder"; }

<section class="max-w-3xl mx-auto space-y-6 px-4">
    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold" style="color: var(--pb-text);">Rating Scale Builder</h1>
            <p style="color: var(--pb-muted);">Users rate on a 1-5 scale.</p>
        </div>
        <a asp-page="/Admin/CreatePoll" class="pb-btn pb-btn-outline">Back</a>
    </div>
    <form method="post" class="space-y-6">
        <div class="pb-card p-6 space-y-4">
            <label class="block">
                <span class="text-sm" style="color: var(--pb-muted);">Question / Title</span>
                <input name="Title" value="@Model.Title" class="mt-2 w-full px-4 py-3 rounded-xl" placeholder="e.g. Rate the event" />
            </label>
            <label class="block">
                <span class="text-sm" style="color: var(--pb-muted);">Description (optional)</span>
                <textarea name="Description" rows="3" class="mt-2 w-full px-4 py-3 rounded-xl" placeholder="Additional context...">@Model.Description</textarea>
            </label>
        </div>
        <div class="flex justify-end"><button type="submit" class="pb-btn pb-btn-gold px-8 py-3">Save</button></div>
    </form>
</section>
