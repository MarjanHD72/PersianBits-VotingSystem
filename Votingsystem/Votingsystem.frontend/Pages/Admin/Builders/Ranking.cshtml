@page
@model Votingsystem.frontend.Pages.Admin.Builders.RankingModel
@{ ViewData["Title"] = "Ranking Builder"; }

<section class="max-w-3xl mx-auto space-y-6 px-4">
    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold" style="color: var(--pb-text);">Ranking Builder</h1>
            <p style="color: var(--pb-muted);">Users drag to rank items by preference.</p>
        </div>
        <a asp-page="/Admin/CreatePoll" class="pb-btn pb-btn-outline">Back</a>
    </div>
    <form method="post" class="space-y-6">
        <div class="pb-card p-6 space-y-4">
            <label class="block">
                <span class="text-sm" style="color: var(--pb-muted);">Title</span>
                <input name="Title" value="@Model.Title" class="mt-2 w-full px-4 py-3 rounded-xl" placeholder="e.g. Rank these modules" />
            </label>
            <label class="block">
                <span class="text-sm" style="color: var(--pb-muted);">Description (optional)</span>
                <textarea name="Description" rows="2" class="mt-2 w-full px-4 py-3 rounded-xl" placeholder="Optional description">@Model.Description</textarea>
            </label>
        </div>
        <div class="pb-card p-6 space-y-4">
            <div class="flex items-center justify-between">
                <h2 class="font-semibold" style="color: var(--pb-text);">Items to Rank</h2>
                <button type="button" id="addOpt" class="pb-btn pb-btn-gold text-sm">+ Add Item</button>
            </div>
            <div id="optList" class="space-y-3"></div>
        </div>
        <div class="flex justify-end"><button type="submit" class="pb-btn pb-btn-gold px-8 py-3">Save</button></div>
    </form>
</section>
@section Scripts {
<script>
    let c=0; const list=document.getElementById('optList');
    function add(){const i=c++;const d=document.createElement('div');d.className='flex gap-2';
    d.innerHTML=`<input name="OptionList[${i}]" class="flex-1 px-4 py-3 rounded-xl" placeholder="Item ${i+1}" />
    <button type="button" onclick="this.parentElement.remove()" class="pb-btn pb-btn-danger-outline text-sm">X</button>`;
    list.appendChild(d);}
    document.getElementById('addOpt').addEventListener('click',add);add();add();add();
</script>
}
