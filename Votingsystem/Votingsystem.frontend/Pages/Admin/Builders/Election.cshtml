@page
@model VotingSystem.Frontend.Pages.Admin.Builders.ElectionModel
@{
    ViewData["Title"] = "Election Builder";
}

<section class="max-w-5xl mx-auto space-y-8">

    <!-- Header -->
    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold">Admin Election Builder</h1>
            <p class="text-slate-400">Create candidates with image and description.</p>
        </div>

        <a asp-page="/Admin/CreatePoll"
           class="px-4 py-3 rounded-xl border border-slate-700 hover:bg-slate-800/60">
            Back
        </a>
    </div>

    <!-- Election Info -->
    <div class="glass-card p-6 space-y-4">
        <h2 class="text-lg font-semibold">Election Details</h2>

        <div class="space-y-2">
            <label class="text-sm text-slate-300">Election Title</label>
            <input type="text"
                   placeholder="e.g. Student President 2026"
                   class="w-full px-4 py-3 rounded-xl bg-black/60 border border-slate-700 focus:border-[#D4AF37] outline-none text-slate-100" />
        </div>

        <div class="space-y-2">
            <label class="text-sm text-slate-300">Description</label>
            <textarea rows="3"
                      placeholder="Short description about this election..."
                      class="w-full px-4 py-3 rounded-xl bg-black/60 border border-slate-700 focus:border-[#D4AF37] outline-none text-slate-100"></textarea>
        </div>
    </div>

    <!-- Candidates Section -->
    <div class="glass-card p-6 space-y-6">

        <div class="flex items-center justify-between">
            <h2 class="text-lg font-semibold">Candidates</h2>

            <button id="addCandidate"
                    class="px-4 py-2 rounded-xl bg-[#D4AF37] text-black font-medium hover:bg-[#FFC94A] transition">
                + Add Candidate
            </button>
        </div>

        <div id="candidateList" class="space-y-6"></div>

    </div>

    <!-- Save -->
    <div class="flex justify-end">
        <button class="px-6 py-3 rounded-2xl font-semibold bg-emerald-500 hover:bg-emerald-600 transition text-white shadow-lg">
            Save Election
        </button>
    </div>

</section>

<style>
    .glass-card {
        background: rgba(0,0,0,0.55);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(212,175,55,0.2);
        border-radius: 24px;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {

        const list = document.getElementById("candidateList");
        const addBtn = document.getElementById("addCandidate");

        function createCandidateCard() {
            const wrapper = document.createElement("div");
            wrapper.className = "p-5 rounded-2xl bg-black/60 border border-slate-800 space-y-4";

            wrapper.innerHTML = `
                <div class="flex justify-between items-center">
                    <h3 class="font-semibold text-lg">Candidate</h3>
                    <button class="text-red-400 hover:text-red-300 text-sm remove-btn">
                        Remove
                    </button>
                </div>

                <div class="space-y-2">
                    <label class="text-sm text-slate-300">Full Name</label>
                    <input type="text"
                           class="w-full px-4 py-3 rounded-xl bg-black/60 border border-slate-700 focus:border-[#D4AF37] outline-none text-slate-100"
                           placeholder="Candidate name" />
                </div>

                <div class="space-y-2">
                    <label class="text-sm text-slate-300">Upload Image</label>
                    <input type="file"
                           class="w-full text-sm text-slate-300 file:bg-[#D4AF37] file:text-black file:px-3 file:py-1 file:rounded-lg file:border-0" />
                </div>

                <div class="space-y-2">
                    <label class="text-sm text-slate-300">Description</label>
                    <textarea rows="3"
                              class="w-full px-4 py-3 rounded-xl bg-black/60 border border-slate-700 focus:border-[#D4AF37] outline-none text-slate-100"
                              placeholder="Candidate background, goals, manifesto..."></textarea>
                </div>
            `;

            wrapper.querySelector(".remove-btn").addEventListener("click", () => {
                wrapper.remove();
            });

            list.appendChild(wrapper);
        }

        addBtn.addEventListener("click", createCandidateCard);

        // Add first candidate automatically
        createCandidateCard();
    });
</script>