@page
@model Votingsystem.frontend.Pages.Admin.Builders.ElectionModel
@{ ViewData["Title"] = "Election Builder"; }

<section class="max-w-5xl mx-auto space-y-8 px-4">
    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold" style="color: var(--pb-text);">Election Builder</h1>
            <p style="color: var(--pb-muted);">Create candidates with photo and description.</p>
        </div>
        <a asp-page="/Admin/CreatePoll" class="pb-btn pb-btn-outline">Back</a>
    </div>

    <form method="post" enctype="multipart/form-data" id="electionForm">
        <div class="pb-card p-6 space-y-4">
            <h2 class="text-lg font-semibold" style="color: var(--pb-text);">Election Details</h2>
            <div class="space-y-2">
                <label class="text-sm" style="color: var(--pb-muted);">Election Title</label>
                <input name="Title" value="@Model.Title" placeholder="e.g. Student President 2026" class="w-full px-4 py-3 rounded-xl" />
            </div>
            <div class="space-y-2">
                <label class="text-sm" style="color: var(--pb-muted);">Description</label>
                <textarea name="Description" rows="3" placeholder="Short description..." class="w-full px-4 py-3 rounded-xl">@Model.Description</textarea>
            </div>
        </div>

        <div class="pb-card p-6 space-y-6 mt-6">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-semibold" style="color: var(--pb-text);">Candidates</h2>
                <button type="button" id="addCandidate" class="pb-btn pb-btn-gold text-sm">+ Add Candidate</button>
            </div>
            <div id="candidateList" class="space-y-6"></div>
        </div>

        <div class="flex justify-end mt-6">
            <button type="submit" class="pb-btn pb-btn-gold px-8 py-3">Save Election</button>
        </div>
    </form>
</section>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const list = document.getElementById('candidateList');
        const addBtn = document.getElementById('addCandidate');
        let count = 0;

        function addCard() {
            const i = count++;
            const div = document.createElement('div');
            div.className = 'pb-card-flat p-5 space-y-4';
            div.innerHTML = `
                <div class="flex justify-between items-center">
                    <h3 class="font-semibold" style="color: var(--pb-text);">Candidate ${i + 1}</h3>
                    <button type="button" class="remove-btn" style="color: var(--pb-danger); font-size: 0.875rem; cursor: pointer; background:none; border:none;">Remove</button>
                </div>
                <div class="space-y-2">
                    <label class="text-sm" style="color: var(--pb-muted);">Full Name</label>
                    <input name="CandidateList[${i}].Name" class="w-full px-4 py-3 rounded-xl" placeholder="Candidate name" />
                </div>
                <div class="space-y-2">
                    <label class="text-sm" style="color: var(--pb-muted);">Photo</label>
                    <input type="file" name="CandidateImage_${i}" accept="image/*"
                           class="w-full px-4 py-3 rounded-xl" style="background: var(--pb-inputBg); border: 1px solid var(--pb-inputBorder); color: var(--pb-text);" />
                    <span class="text-xs" style="color: var(--pb-muted2);">Upload from your device. JPG, PNG supported.</span>
                </div>
                <div class="space-y-2">
                    <label class="text-sm" style="color: var(--pb-muted);">Description</label>
                    <textarea name="CandidateList[${i}].Description" rows="3" class="w-full px-4 py-3 rounded-xl" placeholder="Background, goals..."></textarea>
                </div>
            `;
            div.querySelector('.remove-btn').addEventListener('click', () => div.remove());
            list.appendChild(div);
        }

        addBtn.addEventListener('click', addCard);
        addCard();
    });
</script>
}
