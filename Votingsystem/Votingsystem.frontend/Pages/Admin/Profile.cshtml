@page
@model Votingsystem.frontend.Pages.Admin.ProfileModel
@{
    ViewData["Title"] = "Admin Profile";
}

<section class="max-w-3xl mx-auto space-y-6">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <h1 class="text-2xl font-bold" style="color:var(--pb-text);">Profile</h1>
        <a asp-page="/Admin/Dashboard" class="pb-btn pb-btn-outline text-sm">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Dashboard
        </a>
    </div>

    @if (Model.Profile != null)
    {
        <!-- Avatar card -->
        <div class="pb-card p-8">
            <div style="display:flex;flex-direction:column;align-items:center;gap:16px;text-align:center;">
                <div style="position:relative;">
                    <div style="width:100px;height:100px;border-radius:50%;display:flex;align-items:center;justify-content:center;
                                font-size:2.8rem;background:var(--pb-avatarBg);
                                border:3px solid var(--pb-gold);box-shadow:var(--pb-shadowGlow), 0 0 40px rgba(212,175,55,0.15);">
                        @Model.Profile.Avatar
                    </div>
                    <button type="button" id="changeAvatarBtn"
                            style="position:absolute;bottom:-4px;right:-4px;width:32px;height:32px;border-radius:50%;
                                   background:linear-gradient(135deg,var(--pb-gold),var(--pb-goldGlow));border:none;
                                   cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:0.8rem;
                                   box-shadow:0 2px 8px rgba(212,175,55,0.35);">
                        ✏️
                    </button>
                </div>
                <div>
                    <h2 class="text-xl font-bold" style="color:var(--pb-text);">@Model.Profile.FullName</h2>
                    <div style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:6px;">
                        <span class="pb-badge pb-badge-gold">
                            <svg width="10" height="10" fill="currentColor" viewBox="0 0 24 24" style="margin-right:3px;"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                            Admin
                        </span>
                    </div>
                </div>
                <p style="font-size:0.8rem;color:var(--pb-muted2);">Click the pencil to change your avatar</p>
            </div>
        </div>

        <!-- Stats -->
        <div class="grid sm:grid-cols-3 gap-4">
            <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:12px;">
                <div style="width:38px;height:38px;border-radius:12px;background:var(--pb-goldSubtle);border:1px solid var(--pb-goldBorder);
                            display:flex;align-items:center;justify-content:center;font-size:1.1rem;">🗳️</div>
                <div>
                    <p class="pb-stat-value">@Model.ElectionCount</p>
                    <p class="pb-stat-label" style="margin-top:4px;">Elections</p>
                </div>
            </div>
            <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:12px;">
                <div style="width:38px;height:38px;border-radius:12px;background:rgba(124,58,237,0.12);border:1px solid rgba(124,58,237,0.25);
                            display:flex;align-items:center;justify-content:center;font-size:1.1rem;">🔢</div>
                <div>
                    <p class="pb-stat-value" style="color:var(--pb-purple);">@Model.TotalVotes</p>
                    <p class="pb-stat-label" style="margin-top:4px;">Total Votes</p>
                </div>
            </div>
            <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:12px;">
                <div style="width:38px;height:38px;border-radius:12px;background:var(--pb-successBg);border:1px solid var(--pb-successBdr);
                            display:flex;align-items:center;justify-content:center;font-size:1.1rem;">▶️</div>
                <div>
                    <p class="pb-stat-value" style="color:var(--pb-success);">@Model.ActiveCount</p>
                    <p class="pb-stat-label" style="margin-top:4px;">Active</p>
                </div>
            </div>
        </div>

        <!-- Account details -->
        <div class="pb-card p-6 space-y-0">
            <h3 style="font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--pb-gold);margin-bottom:16px;">
                Account Details
            </h3>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:13px 0;border-bottom:1px solid var(--pb-border2);">
                <span style="color:var(--pb-muted2);font-size:0.85rem;display:flex;align-items:center;gap:8px;">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    Email
                </span>
                <span style="color:var(--pb-text);font-size:0.9rem;">@Model.Profile.Email</span>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:13px 0;border-bottom:1px solid var(--pb-border2);">
                <span style="color:var(--pb-muted2);font-size:0.85rem;display:flex;align-items:center;gap:8px;">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Date of Birth
                </span>
                <span style="color:var(--pb-text);font-size:0.9rem;">@Model.Profile.DateOfBirth.ToString("MMM dd, yyyy")</span>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:13px 0;">
                <span style="color:var(--pb-muted2);font-size:0.85rem;display:flex;align-items:center;gap:8px;">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Member since
                </span>
                <span style="color:var(--pb-text);font-size:0.9rem;">@Model.Profile.CreatedAt.ToString("MMM dd, yyyy")</span>
            </div>
        </div>

        <!-- Avatar Picker Modal -->
        <div id="avatarModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:50;
                                     align-items:center;justify-content:center;padding:1rem;">
            <div class="pb-card p-6 space-y-4" style="max-width:440px;width:100%;">
                <div style="display:flex;align-items:center;justify-content:space-between;">
                    <h3 class="font-bold text-lg" style="color:var(--pb-text);">Choose Avatar</h3>
                    <button id="avatarCloseBtn" class="pb-btn pb-btn-outline text-sm" style="padding:0.3rem 0.7rem;">✕</button>
                </div>
                <div id="avatarGrid" style="display:grid;grid-template-columns:repeat(6,1fr);gap:10px;"></div>
            </div>
        </div>

        <form id="avatarForm" method="post" asp-page-handler="Avatar" style="display:none;">
            <input type="hidden" name="avatar" id="avatarInput" />
        </form>
    }

</section>

@section Scripts {
    <script>
        (() => {
            const emojis = ['😀','😎','🤠','🥳','😺','🦊','🐶','🐱','🐻','🐼','🦁','🐯','🐸','🐵','🦉','🦄','🐲','🐙','🦋','🌸','🌻','⭐','🔥','💎'];
            const modal  = document.getElementById('avatarModal');
            const grid   = document.getElementById('avatarGrid');

            grid.innerHTML = emojis.map(e => `
                <button type="button" data-emoji="${e}"
                        style="width:100%;aspect-ratio:1;border-radius:12px;font-size:1.5rem;
                               background:var(--pb-glass2);border:1.5px solid var(--pb-border2);
                               cursor:pointer;display:flex;align-items:center;justify-content:center;
                               transition:all 0.15s ease;"
                        onmouseover="this.style.borderColor='var(--pb-goldBorder)'"
                        onmouseout="this.style.borderColor='var(--pb-border2)'">${e}</button>
            `).join('');

            grid.addEventListener('click', e => {
                const btn = e.target.closest('[data-emoji]');
                if (!btn) return;
                document.getElementById('avatarInput').value = btn.dataset.emoji;
                document.getElementById('avatarForm').submit();
            });

            document.getElementById('changeAvatarBtn')?.addEventListener('click', () => modal.style.display = 'flex');
            document.getElementById('avatarCloseBtn')?.addEventListener('click',  () => modal.style.display = 'none');
            modal?.addEventListener('click', e => { if (e.target === modal) modal.style.display = 'none'; });
        })();
    </script>
}
