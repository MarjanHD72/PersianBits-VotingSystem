@page
@model Votingsystem.frontend.Pages.Admin.CreatePollModel
@{
    ViewData["Title"] = "Create Content";
}

<section class="max-w-5xl mx-auto space-y-8">

    <!-- Header -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:42px;height:42px;border-radius:14px;background:var(--pb-goldSubtle);border:1px solid var(--pb-goldBorder);
                        display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">✨</div>
            <div>
                <h1 class="text-2xl font-bold" style="color:var(--pb-text);">Create Content</h1>
                <p style="color:var(--pb-muted);font-size:0.85rem;margin-top:2px;">Choose an election type to get started</p>
            </div>
        </div>
        <a asp-page="/Admin/Dashboard" class="pb-btn pb-btn-outline text-sm" style="flex-shrink:0;">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Dashboard
        </a>
    </div>

    <!-- Featured: Election -->
    <a asp-page="/Admin/Builders/Election" style="text-decoration:none;display:block;">
        <div class="pb-card" style="padding:28px;border-color:var(--pb-goldBorder);background:var(--pb-goldSubtle);
                                     transition:all 0.2s ease;cursor:pointer;"
             onmouseover="this.style.boxShadow='var(--pb-shadowGlow)';this.style.transform='translateY(-2px)'"
             onmouseout="this.style.boxShadow='var(--pb-shadow)';this.style.transform='none'">
            <div style="display:flex;flex-direction:column;gap:20px;">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
                    <div style="display:flex;align-items:center;gap:12px;">
                        <div style="width:50px;height:50px;border-radius:16px;background:rgba(212,175,55,0.20);border:1px solid var(--pb-goldBorder);
                                    display:flex;align-items:center;justify-content:center;font-size:1.6rem;flex-shrink:0;">🗳️</div>
                        <div>
                            <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--pb-gold);margin-bottom:3px;">Core Feature</p>
                            <h2 class="text-2xl font-bold" style="color:var(--pb-text);">Election</h2>
                        </div>
                    </div>
                    <div class="pb-btn pb-btn-gold" style="flex-shrink:0;">
                        Create Election
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </div>
                </div>
                <p style="color:var(--pb-muted);font-size:0.9rem;line-height:1.6;max-width:600px;">
                    Create a candidate-based election with photos and descriptions. Voters browse each candidate before submitting their choice.
                </p>
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    <span class="pb-badge pb-badge-gold" style="font-size:0.75rem;">Candidate profiles</span>
                    <span class="pb-badge pb-badge-gold" style="font-size:0.75rem;">Photo support</span>
                    <span class="pb-badge pb-badge-gold" style="font-size:0.75rem;">One vote per user</span>
                    <span class="pb-badge pb-badge-gold" style="font-size:0.75rem;">Real-time results</span>
                </div>
            </div>
        </div>
    </a>

    <!-- Section label -->
    <div style="display:flex;align-items:center;gap:12px;">
        <div style="height:1px;flex:1;background:var(--pb-border2);"></div>
        <p style="font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--pb-muted2);white-space:nowrap;">Other Question Types</p>
        <div style="height:1px;flex:1;background:var(--pb-border2);"></div>
    </div>

    <!-- Secondary types grid -->
    <div class="grid sm:grid-cols-2 gap-4">

        <a asp-page="/Admin/Builders/Multichoice" style="text-decoration:none;">
            <div class="pb-card" style="padding:20px;cursor:pointer;transition:all 0.2s ease;height:100%;"
                 onmouseover="this.style.borderColor='var(--pb-goldBorder)';this.style.transform='translateY(-2px)'"
                 onmouseout="this.style.borderColor='var(--pb-border)';this.style.transform='none'">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                    <div style="display:flex;gap:12px;align-items:flex-start;">
                        <div style="width:44px;height:44px;border-radius:13px;background:var(--pb-glass2);border:1px solid var(--pb-border);
                                    display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">☑️</div>
                        <div>
                            <h3 class="font-bold" style="color:var(--pb-text);">Multichoice</h3>
                            <p style="font-size:0.82rem;color:var(--pb-muted);margin-top:4px;line-height:1.5;">Select one or more choices from a list.</p>
                        </div>
                    </div>
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--pb-muted2);flex-shrink:0;margin-top:4px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
            </div>
        </a>

        <a asp-page="/Admin/Builders/Text" style="text-decoration:none;">
            <div class="pb-card" style="padding:20px;cursor:pointer;transition:all 0.2s ease;height:100%;"
                 onmouseover="this.style.borderColor='var(--pb-goldBorder)';this.style.transform='translateY(-2px)'"
                 onmouseout="this.style.borderColor='var(--pb-border)';this.style.transform='none'">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                    <div style="display:flex;gap:12px;align-items:flex-start;">
                        <div style="width:44px;height:44px;border-radius:13px;background:var(--pb-glass2);border:1px solid var(--pb-border);
                                    display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">📝</div>
                        <div>
                            <h3 class="font-bold" style="color:var(--pb-text);">Text Response</h3>
                            <p style="font-size:0.82rem;color:var(--pb-muted);margin-top:4px;line-height:1.5;">Collect open-ended written responses.</p>
                        </div>
                    </div>
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--pb-muted2);flex-shrink:0;margin-top:4px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
            </div>
        </a>

        <a asp-page="/Admin/Builders/RatingScale" style="text-decoration:none;">
            <div class="pb-card" style="padding:20px;cursor:pointer;transition:all 0.2s ease;height:100%;"
                 onmouseover="this.style.borderColor='var(--pb-goldBorder)';this.style.transform='translateY(-2px)'"
                 onmouseout="this.style.borderColor='var(--pb-border)';this.style.transform='none'">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                    <div style="display:flex;gap:12px;align-items:flex-start;">
                        <div style="width:44px;height:44px;border-radius:13px;background:var(--pb-glass2);border:1px solid var(--pb-border);
                                    display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">⭐</div>
                        <div>
                            <h3 class="font-bold" style="color:var(--pb-text);">Rating Scale</h3>
                            <p style="font-size:0.82rem;color:var(--pb-muted);margin-top:4px;line-height:1.5;">Users rate on a 1–5 numeric scale.</p>
                        </div>
                    </div>
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--pb-muted2);flex-shrink:0;margin-top:4px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
            </div>
        </a>

        <a asp-page="/Admin/Builders/Ranking" style="text-decoration:none;">
            <div class="pb-card" style="padding:20px;cursor:pointer;transition:all 0.2s ease;height:100%;"
                 onmouseover="this.style.borderColor='var(--pb-goldBorder)';this.style.transform='translateY(-2px)'"
                 onmouseout="this.style.borderColor='var(--pb-border)';this.style.transform='none'">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                    <div style="display:flex;gap:12px;align-items:flex-start;">
                        <div style="width:44px;height:44px;border-radius:13px;background:var(--pb-glass2);border:1px solid var(--pb-border);
                                    display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">🏆</div>
                        <div>
                            <h3 class="font-bold" style="color:var(--pb-text);">Ranking</h3>
                            <p style="font-size:0.82rem;color:var(--pb-muted);margin-top:4px;line-height:1.5;">Users drag to rank items by preference.</p>
                        </div>
                    </div>
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--pb-muted2);flex-shrink:0;margin-top:4px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
            </div>
        </a>

    </div>

</section>
