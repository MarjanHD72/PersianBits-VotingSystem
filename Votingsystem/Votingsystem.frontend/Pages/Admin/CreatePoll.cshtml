@page
@model VotingSystem.Frontend.Pages.Admin.CreatePollModel
@{
    ViewData["Title"] = "Add Content";
}

@*
    ADD CONTENT (Admin) - Button-only screen
    ---------------------------------------
    You want a simple “choose what to create” screen like Vevox:
    - Just buttons/cards
    - No complicated forms here
    - Each button will link to a page we build later (not now)

    Backend later:
    - Only creators/admins can access this page
    - Each button will open a builder flow and save to DB
*@

<section class="max-w-5xl mx-auto space-y-6">

    <!-- Header -->
    <div class="flex items-start justify-between gap-4">
        <div class="space-y-1">
            <h1 class="text-2xl font-semibold">Add content</h1>
            <p class="text-slate-400">Choose a question type. We’ll design each one later.</p>
        </div>

        <a asp-page="/Admin/Dashboard"
           class="px-4 py-3 rounded-xl border border-slate-800 hover:bg-slate-800/60">
            Back
        </a>
    </div>

    <!-- Section title -->
    <div class="text-sm text-slate-400">QUESTION TYPES</div>

    <!-- Buttons grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">

        <!-- Multichoice -->
        <a asp-page="/Admin/Builders/Multichoice"
           class="group rounded-2xl border border-slate-800 bg-slate-900/40 p-5 hover:bg-slate-900/70 transition">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold">Multichoice</h2>
                    <p class="text-sm text-slate-400 mt-1">Select one or more choices from a list.</p>
                </div>
                <span class="text-xs px-2 py-1 rounded-full border border-indigo-500/40 text-indigo-300
                             shadow-[0_0_18px_rgba(99,102,241,0.25)]">
                    Open
                </span>
            </div>
        </a>

        <!-- Text -->
        <a asp-page="/Admin/Builders/Text"
           class="group rounded-2xl border border-slate-800 bg-slate-900/40 p-5 hover:bg-slate-900/70 transition">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold">Text</h2>
                    <p class="text-sm text-slate-400 mt-1">Submit open-ended text responses.</p>
                </div>
                <span class="text-xs px-2 py-1 rounded-full border border-indigo-500/40 text-indigo-300">
                    Open
                </span>
            </div>
        </a>

        <!-- Ranking -->
        <a asp-page="/Admin/Builders/Ranking"
           class="group rounded-2xl border border-slate-800 bg-slate-900/40 p-5 hover:bg-slate-900/70 transition">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold">Ranking</h2>
                    <p class="text-sm text-slate-400 mt-1">Rank choices in order of preference.</p>
                </div>
                <span class="text-xs px-2 py-1 rounded-full border border-indigo-500/40 text-indigo-300">
                    Open
                </span>
            </div>
        </a>

        <!-- Rating scale -->
        <a asp-page="/Admin/Builders/RatingScale"
           class="group rounded-2xl border border-slate-800 bg-slate-900/40 p-5 hover:bg-slate-900/70 transition">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold">Rating scale</h2>
                    <p class="text-sm text-slate-400 mt-1">Submit a rating on a numeric scale.</p>
                </div>
                <span class="text-xs px-2 py-1 rounded-full border border-indigo-500/40 text-indigo-300">
                    Open
                </span>
            </div>
        </a>

        <!-- Election / Vote -->
        <a asp-page="/Admin/Builders/Election"
           class="group rounded-2xl border border-slate-800 bg-slate-900/40 p-5 hover:bg-slate-900/70 transition">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold">Election</h2>
                    <p class="text-sm text-slate-400 mt-1">Vote for a person/candidate with live results.</p>
                </div>
                <span class="text-xs px-2 py-1 rounded-full border border-indigo-500/40 text-indigo-300">
                    Open
                </span>
            </div>
        </a>

        <!-- Quick poll -->
        <a asp-page="/Admin/Builders/QuickPoll"
           class="group rounded-2xl border border-slate-800 bg-slate-900/40 p-5 hover:bg-slate-900/70 transition">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold">Quick poll</h2>
                    <p class="text-sm text-slate-400 mt-1">Fast single-question poll setup.</p>
                </div>
                <span class="text-xs px-2 py-1 rounded-full border border-indigo-500/40 text-indigo-300">
                    Open
                </span>
            </div>
        </a>

    </div>

    <p class="text-xs text-slate-500">
        Note: These links point to builder pages we haven’t created yet. Next step we’ll add simple placeholders so no 404.
    </p>

</section>