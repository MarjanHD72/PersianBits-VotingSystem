@page
@model Votingsystem.frontend.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";

    var maxVotes = Model.MaxVotes;

    // Serialize chart data for JS
    var dayLabelsJson  = System.Text.Json.JsonSerializer.Serialize(Model.VotesByDay.Select(d => d.Label).ToList());
    var dayCountsJson  = System.Text.Json.JsonSerializer.Serialize(Model.VotesByDay.Select(d => d.Count).ToList());
    var topTitlesJson  = System.Text.Json.JsonSerializer.Serialize(Model.TopElections.Select(t => t.Title).ToList());
    var topVotesJson   = System.Text.Json.JsonSerializer.Serialize(Model.TopElections.Select(t => t.Votes).ToList());
}

<section class="space-y-8">

    <!-- ═══════════════════════════════════════════════
         HEADER
         ═══════════════════════════════════════════════ -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
            <div class="flex items-center gap-3">
                <div style="width:42px;height:42px;border-radius:14px;background:var(--pb-goldSubtle);border:1px solid var(--pb-goldBorder);display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;">
                    📊
                </div>
                <div>
                    <h1 class="text-2xl font-bold" style="color:var(--pb-text);line-height:1.2;">Admin Dashboard</h1>
                    <p style="color:var(--pb-muted);font-size:0.85rem;" class="mt-0.5">
                        Manage elections &middot; view analytics &middot; track performance
                    </p>
                </div>
            </div>
        </div>
        <div class="flex gap-2 flex-shrink-0">
            <a asp-page="/Admin/CreatePoll" class="pb-btn pb-btn-gold">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                Create Election
            </a>
            <a asp-page="/Admin/Users" class="pb-btn pb-btn-outline">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Users
            </a>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════
         KPI CARDS (6-card grid)
         ═══════════════════════════════════════════════ -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">

        <!-- Total Elections -->
        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:var(--pb-goldSubtle);border-color:var(--pb-goldBorder);">🗳️</div>
                <span class="pb-badge pb-badge-gold" style="font-size:0.68rem;">All time</span>
            </div>
            <div>
                <p class="pb-stat-value">@Model.TotalPolls</p>
                <p class="pb-stat-label" style="margin-top:4px;">Total Elections</p>
            </div>
        </div>

        <!-- Running -->
        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:var(--pb-successBg);border-color:var(--pb-successBdr);">▶️</div>
                @if (Model.RunningCount > 0)
                {
                    <span class="pb-badge pb-badge-success" style="font-size:0.68rem;">Live</span>
                }
                else
                {
                    <span class="pb-badge pb-badge-draft" style="font-size:0.68rem;">None</span>
                }
            </div>
            <div>
                <p class="pb-stat-value" style="color:var(--pb-success);">@Model.RunningCount</p>
                <p class="pb-stat-label" style="margin-top:4px;">Running Elections</p>
            </div>
        </div>

        <!-- Votes Today -->
        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:rgba(59,130,246,0.12);border-color:rgba(59,130,246,0.25);">📥</div>
                <span style="font-size:0.72rem;color:var(--pb-muted2);">Today</span>
            </div>
            <div>
                <p class="pb-stat-value" style="color:var(--pb-blue);">@Model.TodayVotes</p>
                <p class="pb-stat-label" style="margin-top:4px;">Votes Today</p>
            </div>
        </div>

        <!-- Total Votes -->
        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:rgba(124,58,237,0.12);border-color:rgba(124,58,237,0.25);">🔢</div>
                <span style="font-size:0.72rem;color:var(--pb-muted2);">All elections</span>
            </div>
            <div>
                <p class="pb-stat-value" style="color:var(--pb-purple);">@Model.TotalVotes</p>
                <p class="pb-stat-label" style="margin-top:4px;">Total Votes</p>
            </div>
        </div>

        <!-- Total Users -->
        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:rgba(251,191,36,0.12);border-color:rgba(251,191,36,0.25);">👥</div>
                <span style="font-size:0.72rem;color:var(--pb-muted2);">Registered</span>
            </div>
            <div>
                <p class="pb-stat-value" style="color:var(--pb-warning);">@Model.TotalUsers</p>
                <p class="pb-stat-label" style="margin-top:4px;">Total Users</p>
            </div>
        </div>

        <!-- Completion Rate -->
        <div class="pb-stat-card" style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div class="dash-icon-wrap" style="background:var(--pb-successBg);border-color:var(--pb-successBdr);">✅</div>
                <span style="font-size:0.72rem;color:var(--pb-muted2);">@Model.ClosedCount closed</span>
            </div>
            <div>
                <p class="pb-stat-value" style="color:var(--pb-success);">@Model.CompletionRate<span style="font-size:1.1rem;font-weight:500;">%</span></p>
                <p class="pb-stat-label" style="margin-top:4px;">Completion Rate</p>
            </div>
        </div>

    </div>

    <!-- ═══════════════════════════════════════════════
         STATUS SUMMARY PILLS
         ═══════════════════════════════════════════════ -->
    @if (Model.TotalPolls > 0)
    {
        <div class="pb-card" style="padding: 16px 20px;">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                <span style="font-size:0.78rem;font-weight:600;color:var(--pb-muted2);letter-spacing:0.06em;text-transform:uppercase;margin-right:4px;">Breakdown</span>

                <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border-radius:9999px;font-size:0.8rem;font-weight:600;background:var(--pb-successBg);color:var(--pb-success);border:1px solid var(--pb-successBdr);">
                    ▶ Running
                    <span style="font-size:1rem;font-weight:700;">@Model.RunningCount</span>
                    <span style="opacity:0.65;">/ @(Model.TotalPolls > 0 ? Math.Round(Model.RunningCount * 100.0 / Model.TotalPolls) : 0)%</span>
                </span>

                <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border-radius:9999px;font-size:0.8rem;font-weight:600;background:var(--pb-draftBg);color:var(--pb-draftText);border:1px solid var(--pb-draftBdr);">
                    ◼ Draft
                    <span style="font-size:1rem;font-weight:700;">@Model.DraftCount</span>
                    <span style="opacity:0.65;">/ @(Model.TotalPolls > 0 ? Math.Round(Model.DraftCount * 100.0 / Model.TotalPolls) : 0)%</span>
                </span>

                <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border-radius:9999px;font-size:0.8rem;font-weight:600;background:var(--pb-dangerBg);color:var(--pb-danger);border:1px solid var(--pb-dangerBdr);">
                    ■ Closed
                    <span style="font-size:1rem;font-weight:700;">@Model.ClosedCount</span>
                    <span style="opacity:0.65;">/ @(Model.TotalPolls > 0 ? Math.Round(Model.ClosedCount * 100.0 / Model.TotalPolls) : 0)%</span>
                </span>
            </div>
        </div>
    }

    <!-- ═══════════════════════════════════════════════
         CHART ROW — Votes over time + Status donut
         ═══════════════════════════════════════════════ -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

        <!-- Line chart: Votes last 7 days -->
        <div class="pb-card p-5 lg:col-span-2" style="display:flex;flex-direction:column;gap:16px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div>
                    <h3 style="font-size:0.95rem;font-weight:700;color:var(--pb-text);">Votes – Last 7 Days</h3>
                    <p style="font-size:0.78rem;color:var(--pb-muted2);margin-top:2px;">Daily vote submissions across all your elections</p>
                </div>
                <div style="display:flex;align-items:center;gap:6px;font-size:0.75rem;color:var(--pb-muted2);">
                    <span style="display:inline-block;width:24px;height:3px;border-radius:2px;background:var(--pb-gold);"></span>
                    Votes
                </div>
            </div>
            <div style="position:relative;height:220px;">
                <canvas id="votesLineChart"></canvas>
            </div>
        </div>

        <!-- Donut chart: Status breakdown -->
        <div class="pb-card p-5" style="display:flex;flex-direction:column;gap:16px;">
            <div>
                <h3 style="font-size:0.95rem;font-weight:700;color:var(--pb-text);">Status Breakdown</h3>
                <p style="font-size:0.78rem;color:var(--pb-muted2);margin-top:2px;">Distribution of election states</p>
            </div>
            <div style="position:relative;height:180px;display:flex;align-items:center;justify-content:center;">
                <canvas id="statusDonutChart"></canvas>
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;margin-top:4px;">
                <div style="display:flex;align-items:center;justify-content:space-between;font-size:0.8rem;">
                    <span style="display:flex;align-items:center;gap:6px;">
                        <span style="width:10px;height:10px;border-radius:50%;background:#34d399;flex-shrink:0;"></span>
                        <span style="color:var(--pb-muted);">Running</span>
                    </span>
                    <span style="font-weight:700;color:var(--pb-text);">@Model.RunningCount</span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;font-size:0.8rem;">
                    <span style="display:flex;align-items:center;gap:6px;">
                        <span style="width:10px;height:10px;border-radius:50%;background:#94a3b8;flex-shrink:0;"></span>
                        <span style="color:var(--pb-muted);">Draft</span>
                    </span>
                    <span style="font-weight:700;color:var(--pb-text);">@Model.DraftCount</span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;font-size:0.8rem;">
                    <span style="display:flex;align-items:center;gap:6px;">
                        <span style="width:10px;height:10px;border-radius:50%;background:#f87171;flex-shrink:0;"></span>
                        <span style="color:var(--pb-muted);">Closed</span>
                    </span>
                    <span style="font-weight:700;color:var(--pb-text);">@Model.ClosedCount</span>
                </div>
            </div>
        </div>

    </div>

    <!-- ═══════════════════════════════════════════════
         TOP ELECTIONS bar chart
         ═══════════════════════════════════════════════ -->
    @if (Model.TopElections.Any())
    {
        <div class="pb-card p-5" style="display:flex;flex-direction:column;gap:16px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <div>
                    <h3 style="font-size:0.95rem;font-weight:700;color:var(--pb-text);">Top Elections by Votes</h3>
                    <p style="font-size:0.78rem;color:var(--pb-muted2);margin-top:2px;">Top @Model.TopElections.Count most-voted elections</p>
                </div>
                <span class="pb-badge pb-badge-gold" style="font-size:0.7rem;">Top @Model.TopElections.Count</span>
            </div>
            <div style="position:relative;height:@(Math.Max(Model.TopElections.Count * 48, 120))px;">
                <canvas id="topElectionsChart"></canvas>
            </div>
        </div>
    }

    <!-- ═══════════════════════════════════════════════
         ELECTIONS LIST (all existing actions preserved)
         ═══════════════════════════════════════════════ -->
    <div class="pb-card p-5 space-y-4">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="font-bold text-lg" style="color:var(--pb-text);">Your Elections</h2>
                <p style="font-size:0.78rem;color:var(--pb-muted2);margin-top:2px;">@Model.Elections.Count election@(Model.Elections.Count == 1 ? "" : "s") total</p>
            </div>
            @if (Model.Elections.Count > 0)
            {
                <a asp-page="/Admin/CreatePoll" class="pb-btn pb-btn-gold text-sm" style="padding:0.5rem 1rem;">+ Add New</a>
            }
        </div>

        @if (Model.Elections.Count == 0)
        {
            <div style="text-align:center;padding:40px 20px;">
                <div style="font-size:2.5rem;margin-bottom:12px;">🗳️</div>
                <p style="color:var(--pb-muted);font-size:0.9rem;font-weight:500;">No elections yet.</p>
                <p style="color:var(--pb-muted2);font-size:0.82rem;margin-top:4px;">Create your first election to get started.</p>
                <a asp-page="/Admin/CreatePoll" class="pb-btn pb-btn-gold" style="margin-top:16px;display:inline-flex;">Create Election</a>
            </div>
        }

        @foreach (var el in Model.Elections)
        {
            var voteCount  = el.Votes.Count;
            var candCount  = el.Candidates.Count;
            var pctWidth   = (int)Math.Round(voteCount * 100.0 / maxVotes);
            var typeLabel  = el.Type switch {
                "election"   => "Election",
                "rating"     => "Rating",
                "text"       => "Text",
                "multichoice"=> "Multi-choice",
                "ranking"    => "Ranking",
                _            => el.Type.ToUpper()
            };
            var typeIcon = el.Type switch {
                "election"   => "🗳️",
                "rating"     => "⭐",
                "text"       => "📝",
                "multichoice"=> "☑️",
                "ranking"    => "🏆",
                _            => "📊"
            };

            <div class="pb-card-flat" style="padding:18px 20px;">
                <!-- Top row: title + badges + actions -->
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">

                    <!-- Left: meta -->
                    <div style="min-width:0;flex:1;">
                        <!-- Title row -->
                        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                            <span style="font-size:1.1rem;">@typeIcon</span>
                            <p class="font-semibold" style="color:var(--pb-text);font-size:0.97rem;word-break:break-word;">@el.Title</p>
                            @if (el.Status == "running")
                            {
                                <span class="pb-badge pb-badge-success">
                                    <span style="width:6px;height:6px;border-radius:50%;background:var(--pb-success);display:inline-block;margin-right:4px;animation:pulse 1.5s infinite;"></span>
                                    Running
                                </span>
                            }
                            else if (el.Status == "closed")
                            {
                                <span class="pb-badge pb-badge-danger">Closed</span>
                            }
                            else
                            {
                                <span class="pb-badge pb-badge-draft">Draft</span>
                            }
                            <span class="pb-badge pb-badge-gold" style="font-size:0.68rem;">@typeLabel</span>
                        </div>

                        <!-- Stats row -->
                        <div style="display:flex;align-items:center;gap:16px;margin-top:10px;flex-wrap:wrap;">
                            <span style="display:flex;align-items:center;gap:5px;font-size:0.82rem;color:var(--pb-muted);">
                                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                                <strong style="color:var(--pb-text);font-weight:700;">@voteCount</strong> vote@(voteCount == 1 ? "" : "s")
                            </span>
                            @if (candCount > 0)
                            {
                                <span style="display:flex;align-items:center;gap:5px;font-size:0.82rem;color:var(--pb-muted);">
                                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20v-1a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v1"/></svg>
                                    <strong style="color:var(--pb-text);font-weight:700;">@candCount</strong> candidate@(candCount == 1 ? "" : "s")
                                </span>
                            }
                            <span style="display:flex;align-items:center;gap:5px;font-size:0.78rem;color:var(--pb-muted2);">
                                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                                @el.CreatedAt.ToString("MMM d, yyyy")
                            </span>
                        </div>

                        <!-- Participation bar -->
                        <div style="margin-top:10px;">
                            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
                                <span style="font-size:0.72rem;color:var(--pb-muted2);letter-spacing:0.05em;text-transform:uppercase;">Participation</span>
                                <span style="font-size:0.72rem;font-weight:700;color:var(--pb-muted);">@pctWidth%</span>
                            </div>
                            <div class="pb-progress" style="height:6px;">
                                <div class="pb-progress-fill" style="width:@pctWidth%;"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: action buttons -->
                    <div class="flex flex-wrap gap-2" style="flex-shrink:0;align-items:flex-start;">
                        <a href="/Admin/Results?id=@el.Id" class="pb-btn pb-btn-outline text-sm" style="padding:0.45rem 0.9rem;">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12h18M3 6h18M3 18h12"/></svg>
                            Results
                        </a>

                        @if (el.Status == "draft")
                        {
                            <form method="post" asp-page-handler="Start" style="margin:0;">
                                <input type="hidden" name="id" value="@el.Id" />
                                <button type="submit" class="pb-btn pb-btn-gold text-sm" style="padding:0.45rem 0.9rem;">
                                    <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M5 3l14 9-14 9V3z"/></svg>
                                    Start
                                </button>
                            </form>
                            <form method="post" asp-page-handler="Delete" style="margin:0;"
                                  onsubmit="return confirm('Delete this election?');">
                                <input type="hidden" name="id" value="@el.Id" />
                                <button type="submit" class="pb-btn pb-btn-danger-outline text-sm" style="padding:0.45rem 0.9rem;">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 6h18M19 6l-1 14H6L5 6"/><path d="M8 6V4h8v2"/></svg>
                                    Delete
                                </button>
                            </form>
                        }
                        else if (el.Status == "running")
                        {
                            <form method="post" asp-page-handler="Stop" style="margin:0;"
                                  onsubmit="return confirm('Stop this election?');">
                                <input type="hidden" name="id" value="@el.Id" />
                                <button type="submit" class="pb-btn pb-btn-outline text-sm" style="padding:0.45rem 0.9rem;">
                                    <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                                    Stop
                                </button>
                            </form>
                            <button type="button" onclick="toggleShare('share-@el.Id')"
                                    class="pb-btn pb-btn-outline text-sm" style="padding:0.45rem 0.9rem;">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                                Share
                            </button>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Delete" style="margin:0;"
                                  onsubmit="return confirm('Delete this election and all its data?');">
                                <input type="hidden" name="id" value="@el.Id" />
                                <button type="submit" class="pb-btn pb-btn-danger-outline text-sm" style="padding:0.45rem 0.9rem;">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 6h18M19 6l-1 14H6L5 6"/><path d="M8 6V4h8v2"/></svg>
                                    Delete
                                </button>
                            </form>
                        }
                    </div>
                </div>

                <!-- Share panel (running only) — preserved exactly -->
                @if (el.Status == "running")
                {
                    <div id="share-@el.Id" style="display:none;margin-top:14px;">
                        <div class="pb-card-flat" style="padding:16px;background:var(--pb-goldSubtle);border-color:var(--pb-goldBorder);">
                            <p style="font-size:0.82rem;font-weight:600;color:var(--pb-muted);margin-bottom:12px;">
                                📤 Share this election
                            </p>
                            <div class="flex flex-col sm:flex-row gap-3">
                                <input readonly id="link-@el.Id"
                                       value="@($"{HttpContext.Request.Scheme}://{HttpContext.Request.Host}/Poll/Take?session={el.SessionId}")"
                                       class="flex-1 px-4 py-3 rounded-xl text-sm" />
                                <button onclick="copyInput('link-@el.Id', this)" class="pb-btn pb-btn-gold text-sm">Copy Link</button>
                            </div>
                            <div style="display:flex;align-items:center;gap:12px;margin-top:10px;flex-wrap:wrap;">
                                <span style="color:var(--pb-muted);font-size:0.875rem;">
                                    Session ID: <strong style="color:var(--pb-text);font-family:monospace;letter-spacing:0.08em;">@el.SessionId</strong>
                                </span>
                                <button onclick="copyText('@el.SessionId', this)" class="pb-btn pb-btn-outline text-sm" style="padding:0.4rem 0.8rem;">
                                    Copy ID
                                </button>
                            </div>
                        </div>
                    </div>
                }

            </div>
        }
    </div>

    <!-- ═══════════════════════════════════════════════
         JOIN ANOTHER ADMIN'S ELECTION (preserved)
         ═══════════════════════════════════════════════ -->
    <div class="pb-card p-5 space-y-4">
        <div style="display:flex;align-items:center;gap:10px;">
            <div class="dash-icon-wrap" style="background:var(--pb-goldSubtle);border-color:var(--pb-goldBorder);font-size:1.1rem;">🔗</div>
            <div>
                <h2 class="font-semibold text-lg" style="color:var(--pb-text);">Join another admin's election</h2>
                <p style="font-size:0.8rem;color:var(--pb-muted2);margin-top:1px;">Enter a session ID shared by another admin</p>
            </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
            <input id="adminJoinSession" class="flex-1 px-4 py-3 rounded-xl"
                   placeholder="Enter Session ID  e.g. 7F2A-19KD" />
            <button id="adminJoinBtn" class="pb-btn pb-btn-gold">Join Election</button>
        </div>
        <p id="adminJoinError" style="display:none; color: var(--pb-danger); font-size: 0.875rem;"></p>
    </div>

</section>

<!-- ═══════════════════════════════════════════════
     PAGE-SCOPED STYLES
     ═══════════════════════════════════════════════ -->
<style>
    .dash-icon-wrap {
        width: 40px; height: 40px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem; border: 1px solid; flex-shrink: 0;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.4; }
    }
</style>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
(function () {
    // ── Shared theme helpers ────────────────────────────────────────────────
    const style = getComputedStyle(document.documentElement);
    const gold     = '#D4AF37';
    const goldGlow = '#FFC94A';
    const muted    = style.getPropertyValue('--pb-muted').trim()  || '#CFCFCF';
    const gridLine = 'rgba(212,175,55,0.10)';

    Chart.defaults.font.family = "'DM Sans', system-ui, sans-serif";
    Chart.defaults.color       = muted;

    // ── 1. Votes – Last 7 Days (Line chart) ────────────────────────────────
    const lineCtx = document.getElementById('votesLineChart');
    if (lineCtx) {
        const labels = @Html.Raw(dayLabelsJson);
        const counts = @Html.Raw(dayCountsJson);

        new Chart(lineCtx, {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    label: 'Votes',
                    data: counts,
                    borderColor: gold,
                    backgroundColor: 'rgba(212,175,55,0.10)',
                    pointBackgroundColor: gold,
                    pointBorderColor: '#0D0D0D',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    borderWidth: 2.5,
                    tension: 0.4,
                    fill: true,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(13,13,13,0.92)',
                        borderColor: 'rgba(212,175,55,0.30)',
                        borderWidth: 1,
                        titleColor: gold,
                        bodyColor: '#F5F5F5',
                        padding: 10,
                        callbacks: {
                            label: ctx => ` ${ctx.parsed.y} vote${ctx.parsed.y !== 1 ? 's' : ''}`
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { color: gridLine },
                        ticks: { color: muted, font: { size: 11 } },
                        border: { color: gridLine }
                    },
                    y: {
                        grid: { color: gridLine },
                        ticks: {
                            color: muted, font: { size: 11 },
                            stepSize: 1,
                            callback: v => Number.isInteger(v) ? v : ''
                        },
                        border: { color: gridLine },
                        beginAtZero: true
                    }
                }
            }
        });
    }

    // ── 2. Status Breakdown (Donut) ─────────────────────────────────────────
    const donutCtx = document.getElementById('statusDonutChart');
    if (donutCtx) {
        const running = @Model.RunningCount;
        const draft   = @Model.DraftCount;
        const closed  = @Model.ClosedCount;
        const total   = running + draft + closed;

        new Chart(donutCtx, {
            type: 'doughnut',
            data: {
                labels: ['Running', 'Draft', 'Closed'],
                datasets: [{
                    data: total > 0 ? [running, draft, closed] : [1, 1, 1],
                    backgroundColor: total > 0
                        ? ['rgba(52,211,153,0.85)', 'rgba(148,163,184,0.70)', 'rgba(248,113,113,0.85)']
                        : ['rgba(52,211,153,0.15)', 'rgba(148,163,184,0.15)', 'rgba(248,113,113,0.15)'],
                    borderColor: total > 0
                        ? ['#34d399', '#94a3b8', '#f87171']
                        : ['rgba(52,211,153,0.30)', 'rgba(148,163,184,0.30)', 'rgba(248,113,113,0.30)'],
                    borderWidth: 2,
                    hoverOffset: 4,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '68%',
                plugins: {
                    legend: { display: false },
                    tooltip: total > 0 ? {
                        backgroundColor: 'rgba(13,13,13,0.92)',
                        borderColor: 'rgba(212,175,55,0.30)',
                        borderWidth: 1,
                        titleColor: gold,
                        bodyColor: '#F5F5F5',
                        padding: 10,
                    } : { enabled: false }
                }
            }
        });
    }

    // ── 3. Top Elections (Horizontal Bar) ──────────────────────────────────
    const barCtx = document.getElementById('topElectionsChart');
    if (barCtx) {
        const titles = @Html.Raw(topTitlesJson);
        const votes  = @Html.Raw(topVotesJson);

        new Chart(barCtx, {
            type: 'bar',
            data: {
                labels: titles,
                datasets: [{
                    label: 'Votes',
                    data: votes,
                    backgroundColor: votes.map((_, i) =>
                        i === 0 ? 'rgba(212,175,55,0.85)'
                        : i === 1 ? 'rgba(212,175,55,0.65)'
                        : 'rgba(212,175,55,0.40)'
                    ),
                    borderColor: votes.map((_, i) =>
                        i === 0 ? '#D4AF37'
                        : i === 1 ? 'rgba(212,175,55,0.80)'
                        : 'rgba(212,175,55,0.50)'
                    ),
                    borderWidth: 1,
                    borderRadius: 8,
                    borderSkipped: false,
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(13,13,13,0.92)',
                        borderColor: 'rgba(212,175,55,0.30)',
                        borderWidth: 1,
                        titleColor: gold,
                        bodyColor: '#F5F5F5',
                        padding: 10,
                        callbacks: {
                            label: ctx => ` ${ctx.parsed.x} vote${ctx.parsed.x !== 1 ? 's' : ''}`
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { color: gridLine },
                        ticks: {
                            color: muted, font: { size: 11 },
                            stepSize: 1,
                            callback: v => Number.isInteger(v) ? v : ''
                        },
                        border: { color: gridLine },
                        beginAtZero: true
                    },
                    y: {
                        grid: { color: 'transparent' },
                        ticks: { color: muted, font: { size: 12 } },
                        border: { color: gridLine }
                    }
                }
            }
        });
    }

    // ── Existing JS: share toggle, copy helpers, join election ─────────────
    function toggleShare(id) {
        const el = document.getElementById(id);
        if (!el) return;
        el.style.display = el.style.display === 'none' ? 'block' : 'none';
    }
    function copyInput(id, btn) {
        navigator.clipboard.writeText(document.getElementById(id).value).then(() => {
            const o = btn.textContent; btn.textContent = 'Copied!';
            setTimeout(() => btn.textContent = o, 1500);
        });
    }
    function copyText(t, btn) {
        navigator.clipboard.writeText(t).then(() => {
            const o = btn.textContent; btn.textContent = 'Copied!';
            setTimeout(() => btn.textContent = o, 1500);
        });
    }

    // Expose to inline onclick handlers
    window.toggleShare = toggleShare;
    window.copyInput   = copyInput;
    window.copyText    = copyText;

    // Join election
    const joinBtn   = document.getElementById('adminJoinBtn');
    const joinInput = document.getElementById('adminJoinSession');
    const joinErr   = document.getElementById('adminJoinError');
    joinBtn?.addEventListener('click', () => {
        const s = (joinInput.value || '').trim();
        if (!s) {
            joinErr.textContent = 'Please enter a Session ID.';
            joinErr.style.display = 'block';
            return;
        }
        window.location.href = '/Poll/Take?session=' + encodeURIComponent(s);
    });
})();
</script>
}
