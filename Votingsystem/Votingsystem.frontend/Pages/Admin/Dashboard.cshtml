@page
@model Votingsystem.frontend.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

@*
    ADMIN DASHBOARD (Frontend Only)
    ------------------------------
    This page is the control center for creators/admins.

    What it includes (UI only for now):
    - Quick stats cards
    - List of polls with status badges
    - Buttons for actions (Start/Stop/Delete) - these do nothing yet
    - “Share poll” area (invitation link / session code / QR placeholder)

    Later backend will:
    - Load real polls from DB
    - Enforce permissions (only creators/admins)
    - Wire buttons to real actions (start/stop/delete)
    - Generate real invite links, session IDs, QR codes
*@

<section class="space-y-8">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold">Admin Dashboard</h1>
            <p class="text-slate-400 mt-1">Manage your elections and participate in others.</p>
        </div>

        <!-- Primary actions -->
        <div class="flex gap-2">
            <a asp-page="/Admin/CreatePoll"
               class="px-4 py-2 rounded-xl bg-[#D4AF37] hover:bg-[#FFC94A] text-slate-950 font-medium">
                Create Election
            </a>

            <a asp-page="/Admin/Users"
               class="px-4 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60">
                Users
            </a>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-4">
            <p class="text-sm text-slate-400">Total polls</p>
            <p class="text-3xl font-semibold mt-2">6</p>
        </div>

        <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-4">
            <p class="text-sm text-slate-400">Running</p>
            <p class="text-3xl font-semibold mt-2">2</p>
        </div>

        <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-4">
            <p class="text-sm text-slate-400">Submissions today</p>
            <p class="text-3xl font-semibold mt-2">41</p>
        </div>

        <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-4">
            <p class="text-sm text-slate-400">Invites sent</p>
            <p class="text-3xl font-semibold mt-2">18</p>
    </div>
    </div>

    <!-- Poll List -->
    <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-5 space-y-4">
        <div class="flex items-center justify-between">
            <h2 class="font-semibold text-lg">Your Elections</h2>
            <span class="text-xs text-slate-400">Mock data</span>
        </div>

        <!-- Poll Item -->
        <div class="rounded-xl border border-slate-800 bg-slate-950/40 p-4 space-y-4">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <div class="flex items-center gap-2">
                        <p class="font-medium">Student Satisfaction Survey</p>
                        <span class="text-xs px-2 py-1 rounded-full bg-emerald-500/15 text-emerald-300 border border-emerald-500/25">
                            Running
                        </span>
                    </div>
                    <p class="text-sm text-slate-400 mt-1">
                        Election • 148 participants
                    </p>
                </div>

                <div class="flex flex-wrap gap-2">
                    <a href="/Admin/Results?type=election&name=Student+Satisfaction+Survey"
                       class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">
                        Results
                    </a>

                    <button class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">
                        Stop
                    </button>

                    <button type="button"
                            onclick="toggleShare('share1')"
                            class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">
                        Share
                    </button>

                    <button class="px-3 py-2 rounded-xl border border-rose-500/30 hover:bg-rose-500/10 text-sm text-rose-300">
                        Delete
                    </button>
                </div>
            </div>

            <!-- Share Panel -->
            <div id="share1" class="hidden rounded-xl border border-slate-800 bg-slate-900/60 p-4 space-y-3">
                <p class="text-sm text-slate-300 font-medium">Share this election</p>

                <div class="flex flex-col sm:flex-row gap-3">
                    <input readonly id="shareLink1"
                           value="https://persianbits.app/join/7F2A-19KD"
                           class="flex-1 px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 text-sm" />

                    <button onclick="copyToClipboard('shareLink1', this)"
                            class="px-4 py-3 rounded-xl bg-[#D4AF37] hover:bg-[#FFC94A] text-slate-950 text-sm font-medium">
                        Copy Link
                    </button>
                </div>

                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
                    <div class="text-sm text-slate-400">
                        Session ID: <span id="sessionId1" class="font-semibold text-slate-200">7F2A-19KD</span>
                    </div>
                    <button onclick="copyText('7F2A-19KD', this)"
                            class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">
                        Copy Session ID
                    </button>
                </div>
            </div>
        </div>

        <!-- Poll Item -->
        <div class="rounded-xl border border-slate-800 bg-slate-950/40 p-4 space-y-4">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <div class="flex items-center gap-2">
                        <p class="font-medium">Best Module Vote</p>
                        <span class="text-xs px-2 py-1 rounded-full bg-slate-500/20 text-slate-300 border border-slate-500/30">
                            Draft
                        </span>
                    </div>
                    <p class="text-sm text-slate-400 mt-1">
                        Election • 0 participants
                    </p>
                </div>

                <div class="flex flex-wrap gap-2">
                    <a href="/Admin/Results?type=election&name=Best+Module+Vote"
                       class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">
                        Results
                    </a>

                    <button class="px-3 py-2 rounded-xl bg-[#D4AF37] hover:bg-[#FFC94A] text-slate-950 font-medium text-sm">
                        Start
                    </button>

                    <button class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">
                        Edit
                    </button>

                    <button class="px-3 py-2 rounded-xl border border-rose-500/30 hover:bg-rose-500/10 text-sm text-rose-300">
                        Delete
                    </button>
                </div>
        </div>

        <!-- Poll item -->
        <div class="rounded-xl border border-slate-800 bg-slate-950/40 p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="space-y-1">
                <div class="flex items-center gap-2">
                    <p class="font-medium">Event Feedback</p>
                    <span class="text-xs px-2 py-1 rounded-full bg-amber-500/15 text-amber-300 border border-amber-500/25">
                        Stopped
                    </span>
                </div>
                <p class="text-sm text-slate-400">Rating scale • 72 submissions</p>
            </div>

            <div class="flex flex-wrap gap-2">
                <a asp-page="/Admin/Results"
                   class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">
                    View results
                </a>
                <button class="px-3 py-2 rounded-xl border border-slate-800 hover:bg-slate-800/60 text-sm">Share</button>
        </div>
    </div>

    <!-- Join Another Admin's Poll -->
    <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-5 space-y-4">
        <div class="flex items-center justify-between">
            <h2 class="font-semibold text-lg">Join another admin’s election</h2>
            <span class="text-xs text-slate-400">Participate as a voter</span>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
            <input id="adminJoinSession"
                   class="flex-1 px-4 py-3 rounded-xl bg-slate-950 border border-slate-800
                          focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   placeholder="Enter Session ID (e.g. 7F2A-19KD)" />

            <button id="adminJoinBtn"
                    class="px-5 py-3 rounded-xl bg-[#D4AF37] hover:bg-[#FFC94A] text-slate-950 font-semibold">
                Join
            </button>
        </div>
            </div>

        <p id="adminJoinError" class="hidden text-sm text-rose-300"></p>
    </div>

</section>

@section Scripts {
    <script>
        function toggleShare(id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.classList.toggle("hidden");
        }

        function copyToClipboard(inputId, btn) {
            const input = document.getElementById(inputId);
            navigator.clipboard.writeText(input.value).then(() => {
                const orig = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(() => btn.textContent = orig, 1500);
            });
        }

        function copyText(text, btn) {
            navigator.clipboard.writeText(text).then(() => {
                const orig = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(() => btn.textContent = orig, 1500);
            });
        }

        (() => {
          const input = document.getElementById("adminJoinSession");
          const btn = document.getElementById("adminJoinBtn");
          const err = document.getElementById("adminJoinError");

          btn?.addEventListener("click", () => {
            err.classList.add("hidden");
            err.textContent = "";

            const session = (input.value || "").trim();
            if (!session) {
              err.textContent = "Please enter a Session ID.";
              err.classList.remove("hidden");
              return;
            }

            window.location.href = `/Poll/Take?session=${encodeURIComponent(session)}`;
          });
        })();
    </script>
}