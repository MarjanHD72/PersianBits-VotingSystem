@page
@model VotingSystem.Frontend.Pages.Auth.Register.IndexModel
@{
    ViewData["Title"] = "Register";
}

@*
*@

<section class="min-h-[70vh] flex items-center justify-center">

        <div class="text-center space-y-2">
            <h1 class="text-3xl font-semibold">Create your account</h1>
        </div>





                </span>


                    Already have an account? Login
                </a>
            </div>
        </div>

        <p class="text-xs text-slate-500 text-center">
            Prototype: backend will store accounts and process creator approval.
        </p>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
          const $ = (id) => document.getElementById(id);

          const yearsAgo = (n) => {
            const d = new Date();
            d.setFullYear(d.getFullYear() - n);
            return d;
          };

          $("regBtn").addEventListener("click", () => {
            const name = $("regName").value.trim();
            const dobRaw = $("regDob").value;
            const email = $("regEmail").value.trim();
            const p1 = $("regPass").value;
            const p2 = $("regPass2").value;
            const wantsCreator = $("reqCreator").checked;

            const err = $("regError");
            err.classList.add("hidden");
            err.textContent = "";

            if (!name) { err.textContent = "Enter your full name."; err.classList.remove("hidden"); return; }
            if (!dobRaw) { err.textContent = "Select your date of birth."; err.classList.remove("hidden"); return; }

            const dob = new Date(dobRaw + "T00:00:00");
            if (isNaN(dob.getTime())) { err.textContent = "Invalid date of birth."; err.classList.remove("hidden"); return; }

            // 18+ rule
            if (dob > yearsAgo(18)) {
              err.textContent = "You must be 18+ to register.";
              err.classList.remove("hidden");
              return;
            }

            if (!email) { err.textContent = "Enter an email."; err.classList.remove("hidden"); return; }
            if (!p1 || p1.length < 8) { err.textContent = "Password must be at least 8 characters."; err.classList.remove("hidden"); return; }
            if (p1 !== p2) { err.textContent = "Passwords do not match."; err.classList.remove("hidden"); return; }

            // Frontend-only auth state
            localStorage.setItem("pb_isLoggedIn", "true");
            localStorage.setItem("pb_isApprovedCreator", "false"); // approval is manual later
            localStorage.setItem("pb_requestedCreator", wantsCreator ? "true" : "false");

            // Store profile basics (frontend-only placeholders)
            localStorage.setItem("pb_userName", name);
            localStorage.setItem("pb_userDob", dobRaw);
            localStorage.setItem("pb_userEmail", email);

            // Continue pending session if exists
            const pending = localStorage.getItem("pb_pendingSession");
            if (pending) {
              window.location.href = `/Poll/Take?session=${encodeURIComponent(pending)}`;
              return;
            }

            window.location.href = "/User/Dashboard";
          });
        })();
    </script>
}