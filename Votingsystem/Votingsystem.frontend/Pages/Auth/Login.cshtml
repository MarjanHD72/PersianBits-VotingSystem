@page
@model Votingsystem.frontend.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Sign In";
}

<section class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="w-full max-w-md space-y-6">

        <!-- Brand header -->
        <div class="flex flex-col items-center gap-4 text-center">
            <div class="pb-hero-logo" style="width:80px;height:80px;">
                <img src="~/assets/logo.jpg" alt="PersianBits logo" />
            </div>
            <div>
                <h1 class="text-2xl font-bold" style="color:var(--pb-text);">Welcome back</h1>
                <p style="color:var(--pb-muted);font-size:0.88rem;margin-top:4px;">Sign in to PersianBits Voting Centre</p>
            </div>
        </div>

        <!-- Form card -->
        <div class="pb-card p-7 space-y-5">
            <form method="post" class="space-y-5">

                <div class="space-y-1">
                    <label style="font-size:0.8rem;font-weight:600;color:var(--pb-muted2);letter-spacing:0.05em;text-transform:uppercase;">
                        Email Address
                    </label>
                    <input name="Email" type="email" value="@Model.Email"
                           class="w-full px-4 py-3 rounded-xl"
                           placeholder="name@example.com"
                           autocomplete="email" />
                </div>

                <div class="space-y-1">
                    <label style="font-size:0.8rem;font-weight:600;color:var(--pb-muted2);letter-spacing:0.05em;text-transform:uppercase;">
                        Password
                    </label>
                    <input name="Password" type="password"
                           class="w-full px-4 py-3 rounded-xl"
                           placeholder="••••••••"
                           autocomplete="current-password" />
                </div>

                @if (!string.IsNullOrEmpty(Model.Error))
                {
                    <div style="display:flex;align-items:center;gap:8px;padding:12px 14px;border-radius:12px;
                                background:var(--pb-dangerBg);border:1px solid var(--pb-dangerBdr);">
                        <span style="font-size:1rem;flex-shrink:0;">⚠️</span>
                        <p style="color:var(--pb-danger);font-size:0.875rem;margin:0;">@Model.Error</p>
                    </div>
                }

                <button type="submit" class="w-full pb-btn pb-btn-gold" style="padding:0.75rem;font-size:0.95rem;">
                    Sign In
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>

                <div style="border-top:1px solid var(--pb-border2);padding-top:16px;text-align:center;">
                    <a asp-page="/Auth/Register/Index" style="color:var(--pb-gold);font-size:0.875rem;text-decoration:none;font-weight:600;">
                        Don't have an account? <span style="text-decoration:underline;">Create one</span>
                    </a>
                </div>

            </form>
        </div>

        <!-- Dev credentials hint -->
        <div style="display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:12px;
                    background:var(--pb-warningBg);border:1px solid var(--pb-warningBdr);">
            <span style="font-size:0.9rem;flex-shrink:0;">🔧</span>
            <p style="font-size:0.75rem;color:var(--pb-warning);margin:0;line-height:1.5;">
                <strong>Dev default:</strong> admin@persianbits.com / admin123
            </p>
        </div>

    </div>
</section>
