@page
@model Votingsystem.frontend.Pages.Poll.ThanksModel
@{
    ViewData["Title"] = "Thank you";
}

<section class="min-h-[70vh] flex items-center justify-center">
    <div class="max-w-xl text-center space-y-4">
        <h1 class="text-3xl font-semibold" style="color: var(--pb-text);">Thank you!</h1>
        <p style="color: var(--pb-muted);">Your vote has been recorded.</p>
        <a asp-page="/User/Dashboard" class="pb-btn pb-btn-gold">Back to Dashboard</a>
    </div>
</section>
