@page
@model VotingSystem.Frontend.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

@*
  FRONTEND-ONLY LOGIN (Pre-launch Mode)
  - Two buttons:
      1) Login as User
      2) Login as Admin
  - Used only for development/demo
  - Continues pending session if exists
*@

<section class="max-w-xl mx-auto space-y-6">
    <div class="text-center">
        <h1 class="text-3xl font-semibold">PersianBits Voting System</h1>
        <p class="text-slate-400 mt-2">Sign in to continue</p>
    </div>

    <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 space-y-5">

        <label class="block">
            <span class="text-sm text-slate-300">Email</span>
            <input id="loginEmail"
                   class="mt-2 w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   placeholder="name@example.com" />
        </label>

        <label class="block">
            <span class="text-sm text-slate-300">Password</span>
            <input id="loginPass" type="password"
                   class="mt-2 w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   placeholder="••••••••" />
        </label>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-2">

            <!-- Login as User -->
            <button id="loginUserBtn"
                    type="button"
                    class="px-4 py-3 rounded-xl bg-[#D4AF37] hover:bg-[#FFC94A] text-slate-950 font-medium">
                Login as User
            </button>

            <!-- Login as Admin -->
            <button id="loginAdminBtn"
                    type="button"
                    class="px-4 py-3 rounded-xl border border-[#D4AF37]/60 text-indigo-300 hover:bg-[#D4AF37]/10 font-medium">
                Login as Admin
            </button>

        </div>

        <p id="loginError" class="hidden text-sm text-rose-300"></p>

        <div class="pt-2 text-center">
            <a asp-page="/Auth/Register/Index"
               class="text-sm text-indigo-300 hover:text-[#D4AF37]">
                Don’t have an account? Register
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
          const $ = (id) => document.getElementById(id);

          const handleLogin = (asAdmin) => {
            const email = $("loginEmail").value.trim();
            const pass = $("loginPass").value;

            const err = $("loginError");
            err.classList.add("hidden");
            err.textContent = "";

            if (!email) { err.textContent = "Enter your email."; err.classList.remove("hidden"); return; }
            if (!pass)  { err.textContent = "Enter your password."; err.classList.remove("hidden"); return; }

            localStorage.setItem("pb_isLoggedIn", "true");
            localStorage.setItem("pb_userEmail", email);
            localStorage.setItem("pb_isApprovedCreator", asAdmin ? "true" : "false");

            const pending = localStorage.getItem("pb_pendingSession");
            if (pending) {
              window.location.href = `/Poll/Take?session=${encodeURIComponent(pending)}`;
              return;
            }

            window.location.href = asAdmin ? "/Admin/Dashboard" : "/User/Dashboard";
          };

          $("loginUserBtn").addEventListener("click", () => handleLogin(false));
          $("loginAdminBtn").addEventListener("click", () => handleLogin(true));
        })();
    </script>
}