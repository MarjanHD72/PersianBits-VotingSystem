@*
    _Layout.cshtml
    -------------
    This is the shared layout for the entire Razor Pages site.

    - Header + footer live here (shown on every page).
    - Each page injects its content into @RenderBody().
    - Tailwind is included via CDN for a modern UI without extra setup.
*@

@{
    // Page title shown in the browser tab.
    // Individual pages can override this by setting ViewData["Title"].
    var title = ViewData["Title"] as string ?? "PersianBits Voting System";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>

    @* Tailwind CSS (CDN). Easy for prototyping. *@
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-950 text-slate-100 min-h-screen">
    @* Wrapper to keep footer at the bottom *@
    <div class="min-h-screen flex flex-col">

        @* HEADER *@
        <header class="sticky top-0 z-40 backdrop-blur bg-slate-950/70 border-b border-slate-800">
            <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">

                @* Brand / Logo (clicking goes to home page) *@
                <a asp-page="/Index" class="flex items-center gap-2 font-semibold tracking-tight">
                    <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-indigo-500/20 border border-indigo-500/30">
                        <span class="text-indigo-300">P</span>
                    </span>
                    <span>PersianBits Voting System</span>
                </a>

                @*
                    Minimal navigation (your requirement):
                    - No "Admin" or "User" buttons here.
                    - Everyone goes through Login.
                    - Later backend decides where to send them after successful login.
                *@
                <nav class="flex items-center gap-2">
                    <a asp-page="/Auth/Login"
                       class="px-3 py-2 rounded-xl text-sm bg-indigo-500 hover:bg-indigo-400 text-slate-950 font-medium">
                        Login
                    </a>
                </nav>

            </div>
        </header>

        @* MAIN CONTENT (each page renders here) *@
        <main class="max-w-6xl mx-auto px-4 py-8 w-full flex-1">
            @RenderBody()
        </main>

        @* FOOTER *@
        <footer class="border-t border-slate-800/80">
            <div class="max-w-6xl mx-auto px-4 py-6 text-xs text-slate-400 flex items-center justify-between">
                <span>PersianBits Voting System • Frontend prototype</span>
                <span>© @DateTime.Now.Year PersianBits</span>
            </div>
        </footer>

    </div>

    @* Optional per-page scripts *@
    @RenderSection("Scripts", required: false)
</body>
</html>