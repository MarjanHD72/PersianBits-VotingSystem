@page
@model VotingSystem.Frontend.Pages.Join.IndexModel
@{
    ViewData["Title"] = "Join";
}

@*
  JOIN A POLL (Frontend-only)
  - Enter Session ID
  - If not logged in -> redirect to Login
  - If logged in -> go to Poll/Take
  - Uses same pending session storage as landing page
*@

<section class="max-w-2xl mx-auto space-y-6">

    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold">Join an election</h1>
            <p class="text-slate-400 mt-1">Enter the Session ID you received.</p>
        </div>

        <a asp-page="/User/Dashboard"
           class="px-4 py-3 rounded-xl border border-slate-800 hover:bg-slate-800/60">
            Back
        </a>
    </div>

    <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 space-y-4">
        <label class="block">
            <span class="text-sm text-slate-300">Session ID</span>
            <input id="joinSession"
                   class="mt-2 w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800
                          focus:outline-none focus:ring-2 focus:ring-indigo-500"
                   placeholder="e.g. 7F2A-19KD" />
        </label>

        <button id="joinBtn"
                class="w-full px-5 py-3 rounded-xl bg-[#D4AF37] hover:bg-[#FFC94A] text-slate-950 font-semibold">
            Join
        </button>

        <p id="joinError" class="hidden text-sm text-rose-300"></p>

        <p class="text-xs text-slate-500">
            If you’re not signed in, you’ll be asked to login first and then returned to this session.
        </p>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
          const input = document.getElementById("joinSession");
          const btn = document.getElementById("joinBtn");
          const err = document.getElementById("joinError");

          const isLoggedIn = () => localStorage.getItem("pb_isLoggedIn") === "true";

          btn.addEventListener("click", () => {
            err.classList.add("hidden");
            err.textContent = "";

            const session = (input.value || "").trim();
            if (!session) {
              err.textContent = "Please enter a Session ID.";
              err.classList.remove("hidden");
              return;
            }

            localStorage.setItem("pb_pendingSession", session);

            if (!isLoggedIn()) {
              window.location.href = "/Auth/Login";
              return;
            }

            window.location.href = `/Poll/Take?session=${encodeURIComponent(session)}`;
          });
        })();
    </script>
}