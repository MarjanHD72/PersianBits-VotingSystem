@page
@model VotingSystem.Frontend.Pages.User.DashboardModel
@{
    ViewData["Title"] = "User Dashboard";
}

@*
    USER DASHBOARD (Frontend Only)
    ------------------------------
    Requirements you gave:
    - Very simple for users (minimal buttons).
    - Users can join using: invite link / session ID / QR.
    - Users participate in polls (vote, submit, done).

    This dashboard does:
    - One main action: "Join a Poll"
    - One simple list of polls the user can do now (mock data)
    - Keeps UI uncluttered
*@

<section class="space-y-8">

    <!-- Header -->
    <div class="space-y-2">
        <h1 class="text-2xl font-semibold">Welcome</h1>
        <p class="text-slate-400">Join a poll and submit your answers in a few taps.</p>
    </div>

    <!-- Main action: Join -->
    <a asp-page="/Join/Index"
       class="group block rounded-2xl border border-slate-800 bg-slate-900/40 p-6 hover:bg-slate-900/70 transition">
        <div class="flex items-start justify-between gap-4">
            <div>
                <p class="text-sm text-slate-400">Join via link, session ID, or QR</p>
                <h2 class="text-xl font-semibold mt-1">Join a Poll</h2>
                <p class="text-sm text-slate-400 mt-2">
                    If you have a code, you can enter it and start instantly.
                </p>
            </div>

            <!-- Neon-ish chip -->
            <div class="shrink-0 px-4 py-2 rounded-xl font-medium bg-indigo-500 text-slate-950
                        shadow-[0_0_25px_rgba(99,102,241,0.35)] group-hover:bg-indigo-400 transition">
                Join
            </div>
        </div>
    </a>

    <!-- Available polls (mock) -->
    <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-5 space-y-4">
        <div class="flex items-center justify-between">
            <h2 class="font-semibold text-lg">Available now</h2>
            <span class="text-xs text-slate-400">Mock data</span>
        </div>

        <!-- Poll card -->
        <div class="rounded-xl border border-slate-800 bg-slate-950/40 p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="space-y-1">
                <p class="font-medium">Student Satisfaction Survey</p>
                <p class="text-sm text-slate-400">Estimated time: 2 minutes</p>
            </div>

            <!-- Minimal action: Start -->
            <a asp-page="/Poll/Take"
               class="px-4 py-3 rounded-xl bg-indigo-500 hover:bg-indigo-400 text-slate-950 font-medium text-center
                      shadow-[0_0_25px_rgba(99,102,241,0.35)]">
                Start
            </a>
        </div>

        <!-- Poll card -->
        <div class="rounded-xl border border-slate-800 bg-slate-950/40 p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="space-y-1">
                <p class="font-medium">Event Feedback</p>
                <p class="text-sm text-slate-400">Estimated time: 1 minute</p>
            </div>

            <a asp-page="/Poll/Take"
               class="px-4 py-3 rounded-xl border border-slate-800 hover:bg-slate-800/60 font-medium text-center">
                Start
            </a>
        </div>
    </div>

</section>